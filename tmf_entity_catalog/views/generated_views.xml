<odoo>
    <record id="view_tmf_entity_catalog_form" model="ir.ui.view">
        <field name="name">tmf.entity.catalog.form</field>
        <field name="model">tmf.entity.catalog</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="description"/>
                <field name="last_update"/>
                <field name="lifecycle_status"/>
                <field name="name"/>
                <field name="version"/>
                <field name="category"/>
                <field name="related_party"/>
                <field name="valid_for"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_entity_catalog_tree" model="ir.ui.view">
        <field name="name">tmf.entity.catalog.tree</field>
        <field name="model">tmf.entity.catalog</field>
        <field name="arch" type="xml">
            <list>
                <field name="description"/>
                <field name="last_update"/>
                <field name="lifecycle_status"/>
                <field name="name"/>
                <field name="version"/>
                <field name="category"/>
                <field name="related_party"/>
                <field name="valid_for"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_entity_catalog" model="ir.actions.act_window">
        <field name="name">EntityCatalog</field>
        <field name="res_model">tmf.entity.catalog</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_entity_catalog"
              name="EntityCatalog"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_entity_catalog"/>
</odoo>
