<odoo>

    <!-- ============================= -->
    <!-- Form View -->
    <!-- ============================= -->
    <record id="view_tmf_entity_catalog_form" model="ir.ui.view">
        <field name="name">tmf.entity.catalog.form</field>
        <field name="model">tmf.entity.catalog</field>
        <field name="arch" type="xml">
            <form string="Entity Catalog">
                <sheet>

                    <group>
                        <field name="name" required="1"/>
                        <field name="description"/>
                        <field name="version"/>
                        <field name="lifecycle_status"/>
                    </group>

                    <group string="Validity">
                        <field name="valid_for_json"
                               widget="text"
                               placeholder='{"startDateTime": "...", "endDateTime": "..."}'/>
                    </group>

                    <group string="Relations">
                        <field name="category_json"
                               widget="text"
                               placeholder='[{"id": "...", "name": "..."}]'/>
                        <field name="related_party_json"
                               widget="text"
                               placeholder='[{"id": "...", "role": "..."}]'/>
                    </group>

                    <group string="System" col="2">
                        <field name="tmf_id" readonly="1"/>
                        <field name="last_update" readonly="1"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================= -->
    <!-- Tree View -->
    <!-- ============================= -->
    <record id="view_tmf_entity_catalog_tree" model="ir.ui.view">
        <field name="name">tmf.entity.catalog.tree</field>
        <field name="model">tmf.entity.catalog</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="version"/>
                <field name="lifecycle_status"/>
                <field name="last_update"/>
            </list>
        </field>
    </record>

</odoo>
