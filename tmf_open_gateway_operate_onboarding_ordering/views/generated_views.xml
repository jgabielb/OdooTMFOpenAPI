<odoo>
    <record id="view_tmf_ogw_application_tree" model="ir.ui.view">
        <field name="name">tmf.ogw.application.tree</field>
        <field name="model">tmf.ogw.application</field>
        <field name="arch" type="xml">
            <list string="Application">
                <field name="tmf_id"/>
                <field name="commercial_name"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_ogw_application_form" model="ir.ui.view">
        <field name="name">tmf.ogw.application.form</field>
        <field name="model">tmf.ogw.application</field>
        <field name="arch" type="xml">
            <form string="Application">
                <sheet>
                    <group>
                        <field name="commercial_name"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="status"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="payload_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_ogw_application" model="ir.actions.act_window">
        <field name="name">OGW Applications</field>
        <field name="res_model">tmf.ogw.application</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_ogw_application"
              name="OGW Applications"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_ogw_application"/>
</odoo>
