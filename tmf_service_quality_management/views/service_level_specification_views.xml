<odoo>
    <record id="tmf657_sls_tree" model="ir.ui.view">
        <field name="name">tmf.service.level.specification.tree</field>
        <field name="model">tmf.service.level.specification</field>
        <field name="arch" type="xml">
            <list>
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="tmf657_sls_form" model="ir.ui.view">
        <field name="name">tmf.service.level.specification.form</field>
        <field name="model">tmf.service.level.specification</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Service level specification"/></h1>
                        <div class="text-muted">
                            <field name="tmf_id"/>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="description"/>
                            <field name="href"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="General">
                            <group>
                                <group>
                                    <field name="name"/>
                                    <field name="tmf_id"/>
                                    <field name="href"/>
                                </group>
                                <group>
                                    <field name="description"/>
                                </group>
                            </group>
                        </page>
                        <page string="Relationships">
                            <group>
                                <field name="related_service_level_objective_json"/>
                            </group>
                        </page>
                        <page string="Technical / Payload">
                            <group>
                                <field name="valid_for_json"/>
                                <field name="raw_json"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="tmf657_sls_search" model="ir.ui.view">
        <field name="name">tmf.service.level.specification.search</field>
        <field name="model">tmf.service.level.specification</field>
        <field name="arch" type="xml">
            <search string="Search Service Level Specifications">
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="description"/>

                <filter string="With Description" name="with_description" domain="[('description', '!=', False)]"/>

                <separator/>
                <filter string="Group by Name" name="group_name" context="{'group_by': 'name'}"/>
            </search>
        </field>
    </record>
</odoo>
