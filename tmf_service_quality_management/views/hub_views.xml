<odoo>
    <record id="tmf657_hub_tree" model="ir.ui.view">
        <field name="name">tmf657.hub.subscription.tree</field>
        <field name="model">tmf657.hub.subscription</field>
        <field name="arch" type="xml">
            <list>
                <field name="tmf_id"/>
                <field name="callback"/>
                <field name="query"/>
            </list>
        </field>
    </record>

    <record id="tmf657_hub_form" model="ir.ui.view">
        <field name="name">tmf657.hub.subscription.form</field>
        <field name="model">tmf657.hub.subscription</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="callback" placeholder="Callback URL"/></h1>
                        <div class="text-muted">
                            <field name="tmf_id"/>
                        </div>
                    </div>
                    <notebook>
                        <page string="General">
                            <group>
                                <group>
                                    <field name="tmf_id"/>
                                    <field name="callback"/>
                                </group>
                                <group>
                                    <field name="query"/>
                                </group>
                            </group>
                        </page>
                        <page string="Technical / Payload">
                            <group>
                                <field name="headers_json"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="tmf657_hub_search" model="ir.ui.view">
        <field name="name">tmf657.hub.subscription.search</field>
        <field name="model">tmf657.hub.subscription</field>
        <field name="arch" type="xml">
            <search string="Search Hub Subscriptions">
                <field name="tmf_id"/>
                <field name="callback"/>
                <field name="query"/>
                <filter string="With Query" name="with_query" domain="[('query', '!=', False)]"/>
            </search>
        </field>
    </record>
</odoo>
