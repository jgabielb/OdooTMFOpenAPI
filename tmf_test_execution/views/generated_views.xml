<odoo>
    <record id="view_tmf_test_environment_provisioning_execution_tree" model="ir.ui.view">
        <field name="name">tmf.test.environment.provisioning.execution.tree</field>
        <field name="model">tmf.test.environment.provisioning.execution</field>
        <field name="arch" type="xml">
            <list string="Test Environment Provisioning Execution">
                <field name="tmf_id"/>
                <field name="data_correlation_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_test_environment_provisioning_execution_form" model="ir.ui.view">
        <field name="name">tmf.test.environment.provisioning.execution.form</field>
        <field name="model">tmf.test.environment.provisioning.execution</field>
        <field name="arch" type="xml">
            <form string="Test Environment Provisioning Execution">
                <sheet>
                    <group>
                        <field name="data_correlation_id"/>
                        <field name="state"/>
                        <field name="test_environment_allocation_execution_json"/>
                        <field name="test_environment_provisioning_execution_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_test_environment_provisioning_execution" model="ir.actions.act_window">
        <field name="name">Test Environment Provisioning Execution</field>
        <field name="res_model">tmf.test.environment.provisioning.execution</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_test_environment_provisioning_execution" name="Test Environment Provisioning Execution" parent="tmf_base.menu_tmf_root" action="action_tmf_test_environment_provisioning_execution"/>

