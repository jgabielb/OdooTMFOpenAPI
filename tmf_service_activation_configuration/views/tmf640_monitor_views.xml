<odoo>
  <record id="tmf640_monitor_view_tree" model="ir.ui.view">
    <field name="name">tmf640.monitor.tree</field>
    <field name="model">tmf640.monitor</field>
    <field name="arch" type="xml">
      <list>
        <field name="tmf640_id"/>
        <field name="state"/>
        <field name="source_href"/>
      </list>
    </field>
  </record>

  <record id="tmf640_monitor_view_form" model="ir.ui.view">
    <field name="name">tmf640.monitor.form</field>
    <field name="model">tmf640.monitor</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="tmf640_id"/>
            <field name="href"/>
            <field name="state"/>
            <field name="source_href"/>
          </group>
          <group string="Payload">
            <field name="request_json" widget="text"/>
            <field name="response_json" widget="text"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="tmf640_monitor_action" model="ir.actions.act_window">
    <field name="name">TMF640 Monitors</field>
    <field name="res_model">tmf640.monitor</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
