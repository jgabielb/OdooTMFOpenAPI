<odoo>
    <record id="view_tmf_account_form" model="ir.ui.view">
        <field name="name">tmf.account.form</field>
        <field name="model">tmf.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="account_type"/>
                <field name="description"/>
                <field name="last_modified"/>
                <field name="name"/>
                <field name="state"/>
                <field name="account_balance"/>
                <field name="account_relationship"/>
                <field name="contact"/>
                <field name="credit_limit"/>
                <field name="related_party"/>
                <field name="tax_exemption"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_account_tree" model="ir.ui.view">
        <field name="name">tmf.account.tree</field>
        <field name="model">tmf.account</field>
        <field name="arch" type="xml">
            <list>
                <field name="account_type"/>
                <field name="description"/>
                <field name="last_modified"/>
                <field name="name"/>
                <field name="state"/>
                <field name="account_balance"/>
                <field name="account_relationship"/>
                <field name="contact"/>
                <field name="credit_limit"/>
                <field name="related_party"/>
                <field name="tax_exemption"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_account" model="ir.actions.act_window">
        <field name="name">Account</field>
        <field name="res_model">tmf.account</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_account"
              name="Account"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_account"/>
</odoo>
