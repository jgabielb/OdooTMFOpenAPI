<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================= -->
    <!-- TMF666 Account Form View -->
    <!-- ========================= -->
    <record id="view_tmf_account_form" model="ir.ui.view">
        <field name="name">tmf.account.form</field>
        <field name="model">tmf.account</field>
        <field name="arch" type="xml">
            <form string="TMF666 Account">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Account name"/></h1>
                        <div class="text-muted">
                            <field name="resource_type" readonly="1"/>
                        </div>
                    </div>

                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="account_type"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="payment_status"/>
                            <field name="rating_type"/>
                            <field name="last_update" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="General">
                            <group>
                                <group>
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="resource_type" readonly="1"/>
                                </group>
                                <group>
                                    <field name="partner_id"/>
                                    <field name="account_type"/>
                                    <field name="state"/>
                                    <field name="payment_status"/>
                                    <field name="rating_type"/>
                                    <field name="last_update" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Party / Relationships">
                            <group>
                                <group>
                                    <field name="partner_id"/>
                                </group>
                            </group>
                            <group string="Related Party Payload">
                                <field name="related_party_json" widget="text"
                                       placeholder='[{"@type":"RelatedPartyRefOrPartyRoleRef","role":"customer","partyOrPartyRole":{...}}]'/>
                            </group>
                        </page>

                        <page string="Financial / Billing">
                            <group>
                                <group>
                                    <field name="credit_limit_json" widget="text"/>
                                    <field name="financial_account_json" widget="text"/>
                                </group>
                                <group>
                                    <field name="bill_structure_json" widget="text"/>
                                    <field name="default_payment_method_json" widget="text"/>
                                </group>
                            </group>
                        </page>

                        <page string="Balances / Plans / Tax">
                            <group>
                                <group>
                                    <field name="account_balance_json" widget="text"/>
                                    <field name="account_relationship_json" widget="text"/>
                                </group>
                                <group>
                                    <field name="payment_plan_json" widget="text"/>
                                    <field name="tax_exemption_json" widget="text"/>
                                </group>
                            </group>
                        </page>

                        <page string="Contacts / Technical">
                            <group>
                                <field name="contact_json" widget="text"/>
                            </group>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================= -->
    <!-- TMF666 Account Tree View -->
    <!-- ========================= -->
    <record id="view_tmf_account_tree" model="ir.ui.view">
        <field name="name">tmf.account.tree</field>
        <field name="model">tmf.account</field>
        <field name="arch" type="xml">
            <list string="TMF666 Accounts">
                <field name="name"/>
                <field name="resource_type"/>
                <field name="partner_id" optional="show"/>
                <field name="account_type"/>
                <field name="state"/>
                <field name="payment_status"/>
                <field name="last_update"/>
            </list>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Search -->
    <!-- ========================= -->
    <record id="view_tmf_account_search" model="ir.ui.view">
        <field name="name">tmf.account.search</field>
        <field name="model">tmf.account</field>
        <field name="arch" type="xml">
            <search string="Search Accounts">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="resource_type"/>
                <field name="account_type"/>
                <field name="state"/>
                <field name="payment_status"/>
                <field name="last_update"/>

                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Suspended" name="suspended" domain="[('state', '=', 'suspended')]"/>
                <filter string="With Related Party" name="with_partner" domain="[('partner_id', '!=', False)]"/>
                <filter string="Recent" name="recent" domain="[('last_update', '>=', context_today())]"/>

                <separator/>
                <filter string="Group by Account Type" name="group_account_type" context="{'group_by': 'account_type'}"/>
                <filter string="Group by State" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Group by Payment Status" name="group_payment_status" context="{'group_by': 'payment_status'}"/>
                <filter string="Group by Related Party" name="group_partner" context="{'group_by': 'partner_id'}"/>
                <filter string="Group by Last Update" name="group_last_update" context="{'group_by': 'last_update:day'}"/>
            </search>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Action -->
    <!-- ========================= -->
    <record id="action_tmf_account" model="ir.actions.act_window">
        <field name="name">TMF666 Accounts</field>
        <field name="res_model">tmf.account</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tmf_account_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first TMF666 account</p>
            <p>Manage account records, related parties, payment status, billing structures, and technical payload details from this screen.</p>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Menu -->
    <!-- ========================= -->
    <menuitem id="menu_tmf_root" name="TMF666 Account Management" parent="tmf_product_catalog.menu_tmf_root"/>
    <menuitem id="menu_tmf_account"
              name="TMF666 Accounts"
              parent="menu_tmf_root"
              action="action_tmf_account"/>

</odoo>
