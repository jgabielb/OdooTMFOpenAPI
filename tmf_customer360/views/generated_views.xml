<odoo>
    <record id="view_tmf_customer360_tree" model="ir.ui.view">
        <field name="name">tmf.customer360.tree</field>
        <field name="model">tmf.customer360</field>
        <field name="arch" type="xml">
            <list string="Customer360">
                <field name="tmf_id"/>
                <field name="customer_id"/>
                <field name="name"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_customer360_form" model="ir.ui.view">
        <field name="name">tmf.customer360.form</field>
        <field name="model">tmf.customer360</field>
        <field name="arch" type="xml">
            <form string="Customer360">
                <sheet>
                    <group>
                        <field name="customer_id"/>
                        <field name="name"/>
                        <field name="status"/>
                        <field name="status_reason"/>
                    </group>
                    <group>
                        <field name="engaged_party_json"/>
                        <field name="customer_ref_json"/>
                        <field name="related_party_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_customer360" model="ir.actions.act_window">
        <field name="name">Customer360</field>
        <field name="res_model">tmf.customer360</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_customer360" name="Customer360" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_customer360"/>
</odoo>
