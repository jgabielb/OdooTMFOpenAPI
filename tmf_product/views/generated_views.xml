<odoo>
    <record id="view_tmf_product_form" model="ir.ui.view">
        <field name="name">tmf.product.form</field>
        <field name="model">tmf.product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="description"/>
                <field name="is_bundle"/>
                <field name="is_customer_visible"/>
                <field name="name"/>
                <field name="order_date"/>
                <field name="product_serial_number"/>
                <field name="random_att"/>
                <field name="start_date"/>
                <field name="termination_date"/>
                <field name="agreement"/>
                <field name="billing_account"/>
                <field name="place"/>
                <field name="product"/>
                <field name="product_characteristic"/>
                <field name="product_offering"/>
                <field name="product_order_item"/>
                <field name="product_price"/>
                <field name="product_relationship"/>
                <field name="product_specification"/>
                <field name="product_term"/>
                <field name="realizing_resource"/>
                <field name="realizing_service"/>
                <field name="related_party"/>
                <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_product_tree" model="ir.ui.view">
        <field name="name">tmf.product.tree</field>
        <field name="model">tmf.product</field>
        <field name="arch" type="xml">
            <list>
                <field name="description"/>
                <field name="is_bundle"/>
                <field name="is_customer_visible"/>
                <field name="name"/>
                <field name="order_date"/>
                <field name="product_serial_number"/>
                <field name="random_att"/>
                <field name="start_date"/>
                <field name="termination_date"/>
                <field name="agreement"/>
                <field name="billing_account"/>
                <field name="place"/>
                <field name="product"/>
                <field name="product_characteristic"/>
                <field name="product_offering"/>
                <field name="product_order_item"/>
                <field name="product_price"/>
                <field name="product_relationship"/>
                <field name="product_specification"/>
                <field name="product_term"/>
                <field name="realizing_resource"/>
                <field name="realizing_service"/>
                <field name="related_party"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_product" model="ir.actions.act_window">
        <field name="name">Product</field>
        <field name="res_model">tmf.product</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_product"
              name="Product"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_product"/>
</odoo>
