<odoo>
    <record id="view_tmf_payment_form" model="ir.ui.view">
        <field name="name">tmf.payment.form</field>
        <field name="model">tmf.payment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="authorization_code"/>
                <field name="correlator_id"/>
                <field name="description"/>
                <field name="name"/>
                <field name="payment_date"/>
                <field name="status"/>
                <field name="status_date"/>
                <field name="account"/>
                <field name="amount"/>
                <field name="channel"/>
                <field name="payment_item"/>
                <field name="payment_method"/>
                <field name="point_of_interaction"/>
                <field name="related_party"/>
                <field name="tax_amount"/>
                <field name="total_amount"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_payment_tree" model="ir.ui.view">
        <field name="name">tmf.payment.tree</field>
        <field name="model">tmf.payment</field>
        <field name="arch" type="xml">
            <list>
                <field name="authorization_code"/>
                <field name="correlator_id"/>
                <field name="description"/>
                <field name="name"/>
                <field name="payment_date"/>
                <field name="status"/>
                <field name="status_date"/>
                <field name="account"/>
                <field name="amount"/>
                <field name="channel"/>
                <field name="payment_item"/>
                <field name="payment_method"/>
                <field name="point_of_interaction"/>
                <field name="related_party"/>
                <field name="tax_amount"/>
                <field name="total_amount"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_payment" model="ir.actions.act_window">
        <field name="name">Payment</field>
        <field name="res_model">tmf.payment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_payment"
              name="Payment"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_payment"/>
</odoo>
