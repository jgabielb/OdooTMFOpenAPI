<odoo>
  <record id="view_tmf_payment_form" model="ir.ui.view">
    <field name="name">tmf.payment.form</field>
    <field name="model">tmf.payment</field>
    <field name="arch" type="xml">
      <form string="Payment">
        <sheet>
          <group>
            <field name="partner_id"/>
            <field name="account_payment_id"/>
            <field name="invoice_ids" widget="many2many_tags"/>
            <field name="authorization_code"/>
            <field name="correlator_id"/>
            <field name="name"/>
            <field name="description"/>
            <field name="payment_date"/>
            <field name="status"/>
            <field name="status_date"/>

            <!-- JSON fields in your model -->
            <field name="account_json"/>
            <field name="total_amount_json"/>
            <field name="payment_method_json"/>
            <field name="channel_json"/>
            <field name="payment_item_json"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_tmf_payment_list" model="ir.ui.view">
    <field name="name">tmf.payment.list</field>
    <field name="model">tmf.payment</field>
    <field name="arch" type="xml">
      <list string="Payments">
        <field name="partner_id"/>
        <field name="name"/>
        <field name="status"/>
        <field name="payment_date"/>
        <field name="authorization_code"/>
        <field name="correlator_id"/>
      </list>
    </field>
  </record>

  <record id="action_tmf_payment" model="ir.actions.act_window">
    <field name="name">Payment</field>
    <field name="res_model">tmf.payment</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- parent menu must exist; change to your real root menu -->
  <menuitem id="menu_tmf_payment" name="Payment" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_payment"/>
</odoo>
