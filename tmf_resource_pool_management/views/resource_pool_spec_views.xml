<odoo>
  <record id="view_tmf_resource_pool_specification_tree" model="ir.ui.view">
    <field name="name">tmf.resource.pool.specification.tree</field>
    <field name="model">tmf.resource.pool.specification</field>
    <field name="arch" type="xml">
      <list>
        <field name="tmf_id"/>
        <field name="name"/>
        <field name="tmf_type"/>
        <field name="href"/>
      </list>
    </field>
  </record>

  <record id="view_tmf_resource_pool_specification_form" model="ir.ui.view">
    <field name="name">tmf.resource.pool.specification.form</field>
    <field name="model">tmf.resource.pool.specification</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="tmf_id"/>
            <field name="name"/>
            <field name="tmf_type"/>
            <field name="href"/>
          </group>
          <group>
            <field name="description"/>
            <field name="capacity_specification"/>
            <field name="attachment"/>
            <field name="external_identifier"/>
            <field name="feature_specification"/>
            <field name="related_party"/>
            <field name="target_resource_schema"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_tmf_resource_pool_specification" model="ir.actions.act_window">
    <field name="name">ResourcePoolSpecification</field>
    <field name="res_model">tmf.resource.pool.specification</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
