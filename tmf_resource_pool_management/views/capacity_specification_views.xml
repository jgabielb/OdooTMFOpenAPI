<odoo>
  <record id="view_tmf_capacity_specification_tree" model="ir.ui.view">
    <field name="name">tmf.capacity.specification.tree</field>
    <field name="model">tmf.capacity.specification</field>
    <field name="arch" type="xml">
      <list>
        <field name="tmf_id"/>
        <field name="tmf_type"/>
        <field name="href"/>
      </list>
    </field>
  </record>

  <record id="view_tmf_capacity_specification_form" model="ir.ui.view">
    <field name="name">tmf.capacity.specification.form</field>
    <field name="model">tmf.capacity.specification</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="tmf_id"/>
            <field name="tmf_type"/>
            <field name="href"/>
          </group>
          <group>
            <field name="capacity_characteristic_specification"/>
            <field name="external_identifier"/>
            <field name="related_capacity_specification"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_tmf_capacity_specification" model="ir.actions.act_window">
    <field name="name">CapacitySpecification</field>
    <field name="res_model">tmf.capacity.specification</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
