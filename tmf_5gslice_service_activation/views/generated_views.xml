<odoo>
    <record id="view__tree" model="ir.ui.view">
        <field name="name">tmf.5gslice.service.activation.resource.tree</field>
        <field name="model">tmf.5gslice.service.activation.resource</field>
        <field name="arch" type="xml">
            <list string="TMF924 DCS 5G Slice Service Activation">
                <field name="resource_type"/>
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="status"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view__form" model="ir.ui.view">
        <field name="name">tmf.5gslice.service.activation.resource.form</field>
        <field name="model">tmf.5gslice.service.activation.resource</field>
        <field name="arch" type="xml">
            <form string="TMF924 DCS 5G Slice Service Activation">
                <sheet>
                    <group>
                        <field name="resource_type"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="status"/>
                        <field name="state"/>
                        <field name="lifecycle_status"/>
                    </group>
                    <group>
                        <field name="payload_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_" model="ir.actions.act_window">
        <field name="name">TMF924 DCS 5G Slice Service Activation</field>
        <field name="res_model">tmf.5gslice.service.activation.resource</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_" name="TMF924 DCS 5G Slice Service Activation" parent="tmf_base.menu_tmf_root" action="action_"/>
</odoo>
