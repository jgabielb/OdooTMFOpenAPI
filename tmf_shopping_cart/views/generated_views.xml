<odoo>
    <record id="view_tmf_shopping_cart_form" model="ir.ui.view">
        <field name="name">tmf.shopping.cart.form</field>
        <field name="model">tmf.shopping.cart</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="cart_item"/>
                <field name="cart_total_price"/>
                <field name="contact_medium"/>
                <field name="related_party"/>
                <field name="valid_for"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_shopping_cart_tree" model="ir.ui.view">
        <field name="name">tmf.shopping.cart.tree</field>
        <field name="model">tmf.shopping.cart</field>
        <field name="arch" type="xml">
            <list>
                <field name="cart_item"/>
                <field name="cart_total_price"/>
                <field name="contact_medium"/>
                <field name="related_party"/>
                <field name="valid_for"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_shopping_cart" model="ir.actions.act_window">
        <field name="name">ShoppingCart</field>
        <field name="res_model">tmf.shopping.cart</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_shopping_cart"
              name="ShoppingCart"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_shopping_cart"/>
</odoo>
