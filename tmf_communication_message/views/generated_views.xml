<odoo>
    <record id="view_tmf_communication_message_form" model="ir.ui.view">
        <field name="name">tmf.communication.message.form</field>
        <field name="model">tmf.communication.message</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="content"/>
                <field name="description"/>
                <field name="log_flag"/>
                <field name="message_type"/>
                <field name="priority"/>
                <field name="scheduled_send_time"/>
                <field name="send_time"/>
                <field name="send_time_complete"/>
                <field name="subject"/>
                <field name="try_times"/>
                <field name="attachment"/>
                <field name="characteristic"/>
                <field name="receiver"/>
                <field name="sender"/>
                <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_communication_message_tree" model="ir.ui.view">
        <field name="name">tmf.communication.message.tree</field>
        <field name="model">tmf.communication.message</field>
        <field name="arch" type="xml">
            <list>
                <field name="content"/>
                <field name="description"/>
                <field name="log_flag"/>
                <field name="message_type"/>
                <field name="priority"/>
                <field name="scheduled_send_time"/>
                <field name="send_time"/>
                <field name="send_time_complete"/>
                <field name="subject"/>
                <field name="try_times"/>
                <field name="attachment"/>
                <field name="characteristic"/>
                <field name="receiver"/>
                <field name="sender"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_communication_message" model="ir.actions.act_window">
        <field name="name">CommunicationMessage</field>
        <field name="res_model">tmf.communication.message</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_communication_message"
              name="CommunicationMessage"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_communication_message"/>
</odoo>
