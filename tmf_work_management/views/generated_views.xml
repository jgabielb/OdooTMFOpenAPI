<odoo>
    <record id="view_tmf_work_tree" model="ir.ui.view">
        <field name="name">tmf.work.tree</field>
        <field name="model">tmf.work</field>
        <field name="arch" type="xml">
            <list string="Work">
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="description"/>
                <field name="version"/>
                <field name="state"/>
                <field name="work_type"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_work_form" model="ir.ui.view">
        <field name="name">tmf.work.form</field>
        <field name="model">tmf.work</field>
        <field name="arch" type="xml">
            <form string="Work">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="version"/>
                        <field name="state"/>
                        <field name="work_type"/>
                        <field name="work_priority"/>
                        <field name="order_date"/>
                        <field name="expected_completion_date"/>
                        <field name="completion_date"/>
                        <field name="percentage_complete"/>
                    </group>
                    <group>
                        <field name="work_specification_json"/>
                        <field name="work_order_item_json"/>
                        <field name="work_characteristic_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_work" model="ir.actions.act_window">
        <field name="name">Work</field>
        <field name="res_model">tmf.work</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_work_root" name="TMF Assurance Work Management" parent="tmf_product_catalog.menu_tmf_root"/>
    <menuitem id="menu_tmf_work" name="Work Orders" parent="menu_tmf_work_root" action="action_tmf_work"/>

    <record id="view_tmf_work_specification_tree" model="ir.ui.view">
        <field name="name">tmf.work.specification.tree</field>
        <field name="model">tmf.work.specification</field>
        <field name="arch" type="xml">
            <list string="Work Specification">
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="description"/>
                <field name="version"/>
                <field name="lifecycle_status"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_work_specification_form" model="ir.ui.view">
        <field name="name">tmf.work.specification.form</field>
        <field name="model">tmf.work.specification</field>
        <field name="arch" type="xml">
            <form string="Work Specification">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="version"/>
                        <field name="lifecycle_status"/>
                        <field name="is_bundle"/>
                        <field name="is_appointment_required"/>
                        <field name="last_update"/>
                    </group>
                    <group>
                        <field name="spec_characteristic_json"/>
                        <field name="constraint_json"/>
                        <field name="target_entity_schema_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_work_specification" model="ir.actions.act_window">
        <field name="name">Work Specification</field>
        <field name="res_model">tmf.work.specification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_work_specification" name="Work Specifications" parent="menu_tmf_work_root" action="action_tmf_work_specification"/>
</odoo>
