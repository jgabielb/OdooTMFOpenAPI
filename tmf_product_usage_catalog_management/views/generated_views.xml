<odoo>
    <record id="view_tmf_product_usage_specification_tree" model="ir.ui.view">
        <field name="name">tmf.product.usage.specification.tree</field>
        <field name="model">tmf.product.usage.specification</field>
        <field name="arch" type="xml">
            <list string="Product Usage Specification">
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="lifecycle_status"/>
                <field name="version"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_product_usage_specification_form" model="ir.ui.view">
        <field name="name">tmf.product.usage.specification.form</field>
        <field name="model">tmf.product.usage.specification</field>
        <field name="arch" type="xml">
            <form string="Product Usage Specification">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="lifecycle_status"/>
                        <field name="version"/>
                    </group>
                    <group>
                        <field name="payload_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_product_usage_specification" model="ir.actions.act_window">
        <field name="name">Product Usage Specification</field>
        <field name="res_model">tmf.product.usage.specification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_product_usage_specification"
              name="Product Usage Spec"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_product_usage_specification"/>
</odoo>
