{
  "_comment": "Curated SID -> Odoo overrides for tools/gen_sid_coverage.py. Keys are validated against the GB922 v25.5 workbook and the addon scan on every run. Entity keys: '<ABE Name>/<BE Name>' (bare '<BE Name>' allowed when globally unique). Resolve new entries from docs/sid_abe_coverage.todo.json.",
  "version": 1,
  "entity_overrides": {
    "Service ABE/Service": {
      "odoo_models": ["tmf.service"],
      "modules": ["tmf_service_inventory"],
      "note": "TMF638 service inventory; tmf640.service is activation plumbing"
    },
    "Resource ABE/Resource": {
      "odoo_models": ["tmf.resource"],
      "modules": ["tmf_resource_inventory"],
      "note": "TMF639 resource inventory; tmf702.resource is activation plumbing"
    },
    "Permission ABE/Permission": {
      "odoo_models": ["tmf.permission", "tmf672.permission"],
      "note": "TMF644 privacy permission + TMF672 user role permission"
    },
    "Digital Identity ABE/Digitaldentity": {
      "odoo_models": ["tmf.digital.identity"],
      "note": "SID v25.5 spells the entity 'Digitaldentity' (typo); TMF720"
    },
    "Product Configuration ABE/ProductConfiguration": {
      "odoo_models": ["tmf.check.product.configuration", "tmf.query.product.configuration"],
      "note": "TMF760 check/query product configuration operations"
    },
    "Business Partner Bill ABE/PartyBillingCycleSpecification": {
      "odoo_models": ["tmf.billing.cycle.spec"],
      "note": "name drift: TMF model drops the Party prefix"
    },
    "Business Partner Bill ABE/PartyBillPresentationMedia": {
      "odoo_models": ["tmf.bill.presentation.media"],
      "note": "name drift: TMF model drops the Party prefix"
    },
    "Software Resource Specification ABE/SoftwareResourceSpecification": {
      "odoo_models": ["tmf.software.compute.resource.specification"],
      "note": "software/compute management addon"
    },
    "Party Revenue Sharing Model ABE/PartyRevenueSharingModel": {
      "odoo_models": ["tmf.party.rev.sharing.model"],
      "note": "revenue sharing model management addon"
    },
    "Customer Product Order ABE/CustomerProductOrder": {
      "odoo_models": ["sale.order"],
      "modules": ["tmf_product_ordering"],
      "note": "TMF622 product order realized on sale.order (plan.md Phase 4)"
    },
    "Customer Product Order ABE/SalesQuote": {
      "odoo_models": ["tmf.quote", "sale.order"],
      "note": "TMF648 quote; quotation stage of sale.order"
    },
    "Sales Opportunity ABE/SalesOpportunity": {
      "odoo_models": ["crm.lead"],
      "note": "CRM opportunity via tmf_sales / tmf_bridge_crm"
    },
    "Customer Billing Account ABE/CustomerBillingAccount": {
      "odoo_models": ["tmf.billing.account"],
      "note": "TMF666 billing account"
    },
    "Customer Payment ABE/CustomerPayment": {
      "odoo_models": ["tmf.payment", "account.payment"],
      "note": "TMF676 payment wired to account.payment"
    },
    "Customer Problem ABE/CustomerProblem": {
      "odoo_models": ["tmf.trouble.ticket"],
      "note": "TMF621 trouble ticket realizes SID CustomerProblem"
    },
    "Stock Item ABE/StockItem": {
      "odoo_models": ["stock.lot"],
      "modules": ["tmf_resource_inventory"],
      "note": "TMF687 stock; serialized stock.lot"
    },
    "Alarm ABE/ResourceAlarm": {
      "odoo_models": ["tmf.alarm"],
      "note": "TMF642 alarm management"
    }
  },
  "abe_overrides": {
    "Customer Party Roles ABE": {
      "odoo_models": ["res.partner"],
