      "tmf_apis": ["TMF635"],
      "coverage": "full"
    },
    "Project ABE": {
      "odoo_models": ["project.task"],
      "coverage": "partial",
      "note": "work bridged to project.task (tmf_bridge_project)"
    },
    "Test ABE": {
      "coverage": "partial",
      "note": "TMF704/TMF705 test artifacts realized by the tmf_test_* addons"
    }
  },
