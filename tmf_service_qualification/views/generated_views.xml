<odoo>
    <record id="view_tmf_service_qual_form" model="ir.ui.view">
        <field name="name">tmf.service.qualification.form</field>
        <field name="model">tmf.service.qualification</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="qualification_result" widget="badge"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="qualification_kind"/>
                            <field name="external_id"/>
                            <field name="instant_sync_qualification"/>
                            <field name="provide_alternative"/>
                            <field name="provide_unavailability_reason"/>
                        </group>
                        <group>
                            <field name="expected_qualification_date"/>
                            <field name="estimated_response_date"/>
                            <field name="effective_qualification_date"/>
                            <field name="expiration_date"/>
                        </group>
                    </group>

                    <group string="Convenience links (optional)">
                        <field name="place_id"/>
                        <field name="service_specification_id"/>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Payload">
                            <group>
                                <field name="related_party_json"/>
                                <field name="search_criteria_json"/>
                                <field name="service_qualification_item_json"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_service_qual" model="ir.actions.act_window">
        <field name="name">Service Qualification</field>
        <field name="res_model">tmf.service.qualification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_service_qual"
              name="Service Qualification"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_service_qual"/>
</odoo>
