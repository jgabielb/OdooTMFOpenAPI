<odoo>
    <record id="view_tmf_service_qual_form" model="ir.ui.view">
        <field name="name">tmf.service.qualification.form</field>
        <field name="model">tmf.service.qualification</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="qualification_result" 
                                   widget="badge" 
                                   decoration-success="qualification_result == 'qualified'"
                                   decoration-danger="qualification_result == 'unqualified'"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="place_id"/>
                            <field name="service_specification_id"/>
                        </group>
                        <group>
                            <field name="expiration_date"/>
                            <field name="tmf_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_service_qual" model="ir.actions.act_window">
        <field name="name">Service Qualification</field>
        <field name="res_model">tmf.service.qualification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_service_qual"
              name="Service Qualification"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_service_qual"/>
</odoo>