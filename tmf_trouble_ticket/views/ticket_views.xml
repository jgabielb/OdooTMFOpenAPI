<odoo>
    <!-- Form View -->
    <record id="view_tmf_ticket_form" model="ir.ui.view">
        <field name="name">tmf.trouble.ticket.form</field>
        <field name="model">tmf.trouble.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="service_id"/>
                            <field name="creation_date"/>
                        </group>
                        <group>
                            <field name="severity"/>
                            <field name="type"/>
                            <field name="tmf_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_tmf_ticket_tree" model="ir.ui.view">
        <field name="name">tmf.trouble.ticket.list</field>
        <field name="model">tmf.trouble.ticket</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="severity" widget="badge" decoration-danger="severity == 'Critical'"/>
                <field name="status" widget="badge" decoration-success="status == 'Resolved'"/>
                <field name="creation_date"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_tmf_ticket" model="ir.actions.act_window">
        <field name="name">Trouble Tickets</field>
        <field name="res_model">tmf.trouble.ticket</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_tmf_ticket"
              name="Support Tickets"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_ticket"
              sequence="40"/>
</odoo>