<odoo>
    <record id="view_tmf_trouble_ticket_form" model="ir.ui.view">
        <field name="name">tmf.trouble.ticket.form</field>
        <field name="model">tmf.trouble.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Removed statusbar widget since status is now Char -->
                    <field name="status" readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="description"/>
                        <field name="ticket_type"/>
                        <field name="severity"/>
                        <field name="priority"/>
                        <field name="partner_id"/>
                    </group>
                    <group>
                        <field name="creation_date"/>
                        <field name="last_update"/>
                        <field name="requested_resolution_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="view_tmf_trouble_ticket_tree" model="ir.ui.view">
        <field name="name">tmf.trouble.ticket.list</field>
        <field name="model">tmf.trouble.ticket</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="status"/>
                <field name="creation_date"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_trouble_ticket_search" model="ir.ui.view">
        <field name="name">tmf.trouble.ticket.search</field>
        <field name="model">tmf.trouble.ticket</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <field name="status"/>
            </search>
        </field>
    </record>

    <record id="action_tmf_trouble_ticket" model="ir.actions.act_window">
        <field name="name">Trouble Tickets</field>
        <field name="res_model">tmf.trouble.ticket</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_trouble_ticket" name="Trouble Tickets" parent="tmf_base.menu_tmf_root" action="action_tmf_trouble_ticket" sequence="20"/>
</odoo>