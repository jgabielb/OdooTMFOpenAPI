<odoo>
    <record id="view_tmf_resource_usage_tree" model="ir.ui.view">
        <field name="name">tmf.resource.usage.tree</field>
        <field name="model">tmf.resource.usage</field>
        <field name="arch" type="xml">
            <list string="ResourceUsage">
                <field name="tmf_id"/>
                <field name="usage_date"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_resource_usage_form" model="ir.ui.view">
        <field name="name">tmf.resource.usage.form</field>
        <field name="model">tmf.resource.usage</field>
        <field name="arch" type="xml">
            <form string="ResourceUsage">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="usage_date"/>
                    </group>
                    <group>
                        <field name="payload_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_resource_usage" model="ir.actions.act_window">
        <field name="name">Resource Usage</field>
        <field name="res_model">tmf.resource.usage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_resource_usage" name="Resource Usage" parent="tmf_base.menu_tmf_root" action="action_tmf_resource_usage"/>

    <record id="view_tmf_resource_usage_specification_tree" model="ir.ui.view">
        <field name="name">tmf.resource.usage.specification.tree</field>
        <field name="model">tmf.resource.usage.specification</field>
        <field name="arch" type="xml">
            <list string="ResourceUsageSpecification">
                <field name="tmf_id"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_resource_usage_specification_form" model="ir.ui.view">
        <field name="name">tmf.resource.usage.specification.form</field>
        <field name="model">tmf.resource.usage.specification</field>
        <field name="arch" type="xml">
            <form string="ResourceUsageSpecification">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                    <group>
                        <field name="payload_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_resource_usage_specification" model="ir.actions.act_window">
        <field name="name">Resource Usage Specification</field>
        <field name="res_model">tmf.resource.usage.specification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_resource_usage_specification" name="Resource Usage Spec" parent="tmf_base.menu_tmf_root" action="action_tmf_resource_usage_specification"/>
</odoo>
