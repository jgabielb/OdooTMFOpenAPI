<odoo>
    <record id="view_tmf_outage_tree" model="ir.ui.view">
        <field name="name">tmf.outage.tree</field>
        <field name="model">tmf.outage</field>
        <field name="arch" type="xml">
            <list string="Outage">
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="state"/>
                <field name="is_planned"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_outage_form" model="ir.ui.view">
        <field name="name">tmf.outage.form</field>
        <field name="model">tmf.outage</field>
        <field name="arch" type="xml">
            <form string="Outage">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="reason"/>
                        <field name="state"/>
                        <field name="is_planned"/>
                    </group>
                    <group>
                        <field name="payload_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_outage" model="ir.actions.act_window">
        <field name="name">Outage</field>
        <field name="res_model">tmf.outage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_outage" name="Outage" parent="tmf_base.menu_tmf_root" action="action_tmf_outage"/>
</odoo>
