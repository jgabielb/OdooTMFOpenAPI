<odoo>
    <record id="view_tmf_shipping_order_form" model="ir.ui.view">
        <field name="name">tmf.shipping.order.form</field>
        <field name="model">tmf.shipping.order</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="external_id"/>
                        <field name="state"/>
                        <field name="creation_date"/>
                        <field name="status_change_date"/>
                        <field name="shipping_order_date"/>
                        <field name="expected_shipping_start_date"/>
                        <field name="expected_shipping_completion_date"/>
                        <field name="completion_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_shipping_order_tree" model="ir.ui.view">
        <field name="name">tmf.shipping.order.tree</field>
        <field name="model">tmf.shipping.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="external_id"/>
                <field name="state"/>
                <field name="creation_date"/>
                <field name="status_change_date"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_shipping_order" model="ir.actions.act_window">
        <field name="name">Shipping Order</field>
        <field name="res_model">tmf.shipping.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_shipping_order"
              name="Shipping Order"
              parent="tmf_base.menu_tmf_root"
              action="action_tmf_shipping_order"/>
</odoo>
