<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend ProductOffering (product.template) form with TMFC001 wiring tab -->
    <record id="view_product_template_tmfc001_wiring" model="ir.ui.view">
        <field name="name">product.template.tmfc001.wiring</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="tmf_product_catalog.product_template_tmf_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="TMFC001 Cross-API Wiring" name="tmfc001_wiring">
                    <group string="TMF632 — Related Parties">
                        <field name="related_partner_ids" widget="many2many_tags" nolabel="1"/>
                    </group>
                    <group string="TMF669 — Party Roles">
                        <field name="related_party_role_ids" widget="many2many_tags" nolabel="1"/>
                    </group>
                    <group string="TMF633 — Service Specifications">
                        <field name="service_specification_ids" widget="many2many_tags" nolabel="1"/>
                    </group>
                    <group string="TMF634 — Resource Specifications">
                        <field name="resource_specification_ids" widget="many2many_tags" nolabel="1"/>
                    </group>
                    <group string="TMF651 — Agreements">
                        <field name="agreement_ids" widget="many2many_tags" nolabel="1"/>
                    </group>
                    <group string="TMF673/674/675 — Place">
                        <field name="geographic_address_id"/>
                        <field name="geographic_site_id"/>
                        <field name="geographic_location_id"/>
                    </group>
                    <group string="Raw JSON (wire format)">
                        <field name="related_party_json" widget="json" nolabel="1"/>
                        <field name="place_json" widget="json" nolabel="1"/>
                        <field name="agreement_json" widget="json" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
    <!-- Extend ProductSpecification form with linked Service/Resource Specs -->
    <record id="view_product_specification_tmfc001_wiring" model="ir.ui.view">
        <field name="name">product.specification.tmfc001.wiring</field>
        <field name="model">tmf.product.specification</field>
        <field name="inherit_id" ref="tmf_product_catalog.view_product_specification_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/field[@name='description']" position="after">
                <notebook>
                    <page string="Service Specifications (TMF633)" name="service_specs">
                        <field name="service_specification_ids" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="description"/>
                                <field name="lifecycle_status" string="Status"/>
                                <field name="version"/>
                                <field name="is_bundle"/>
                            </list>
                        </field>
                    </page>
                    <page string="Resource Specifications (TMF634)" name="resource_specs">
                        <field name="resource_specification_ids" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="description"/>
                                <field name="lifecycle_status" string="Status"/>
                                <field name="version"/>
                            </list>
                        </field>
                    </page>
                    <page string="Related Parties (TMF632)" name="related_parties">
                        <field name="related_partner_ids" widget="many2many_tags" nolabel="1"/>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Resource Specification views + menu                          -->
    <!-- (The ui_normalizer auto-sorts these under the "Catalog"      -->
    <!--  domain bucket, so we parent directly to menu_tmf_root.)     -->
    <!-- ============================================================ -->

    <!-- Resource Specification form view -->
    <record id="view_resource_specification_form" model="ir.ui.view">
        <field name="name">tmf.resource.specification.form</field>
        <field name="model">tmf.resource.specification</field>
        <field name="arch" type="xml">
            <form string="Resource Specification">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Huawei ONT HG8245H" required="1"/></h1>
                    </div>
                    <group col="4">
                        <group>
                            <field name="description"/>
                            <field name="version"/>
                            <field name="product_tmpl_id"/>
                        </group>
                        <group>
                            <field name="lifecycle_status"/>
                            <field name="last_update" readonly="1"/>
                            <field name="tmf_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Resource Specification list view -->
    <record id="view_resource_specification_tree" model="ir.ui.view">
        <field name="name">tmf.resource.specification.tree</field>
        <field name="model">tmf.resource.specification</field>
        <field name="arch" type="xml">
            <list string="Resource Specifications">
                <field name="name"/>
                <field name="description"/>
                <field name="version"/>
                <field name="lifecycle_status"/>
                <field name="product_tmpl_id"/>
            </list>
        </field>
    </record>

    <!-- Resource Specification action + menu -->
    <record id="action_resource_specification" model="ir.actions.act_window">
        <field name="name">Resource Specifications</field>
        <field name="res_model">tmf.resource.specification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_resource_specification"
              name="Resource Specifications"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_resource_specification"
              sequence="12"/>

</odoo>
