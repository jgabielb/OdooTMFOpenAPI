<odoo>
    <record id="view_tmf702_resource_form" model="ir.ui.view">
        <field name="name">tmf702.resource.form</field>
        <field name="model">tmf702.resource</field>
        <field name="arch" type="xml">
            <form string="TMF702 Resource">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="category"/>
                        <field name="resource_version"/>
                        <field name="resource_status"/>
                        <field name="administrative_state"/>
                        <field name="operational_state"/>
                        <field name="usage_state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf702_resource_tree" model="ir.ui.view">
        <field name="name">tmf702.resource.tree</field>
        <field name="model">tmf702.resource</field>
        <field name="arch" type="xml">
            <list string="TMF702 Resources">
                <field name="name"/>
                <field name="category"/>
                <field name="resource_status"/>
                <field name="administrative_state"/>
                <field name="operational_state"/>
            </list>
        </field>
    </record>

    <record id="action_tmf702_resource" model="ir.actions.act_window">
        <field name="name">TMF702 Resource</field>
        <field name="res_model">tmf702.resource</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf702_resource" name="TMF702 Resource" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf702_resource"/>
</odoo>
