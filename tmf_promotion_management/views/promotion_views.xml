<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_tmf_promotion_list" model="ir.ui.view">
        <field name="name">tmf.promotion.list</field>
        <field name="model">tmf.promotion</field>
        <field name="arch" type="xml">
            <list string="Promotions">
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="lifecycle_status"/>
                <field name="promotion_type"/>
                <field name="pricelist_id"/>
                <field name="last_update"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_promotion_form" model="ir.ui.view">
        <field name="name">tmf.promotion.form</field>
        <field name="model">tmf.promotion</field>
        <field name="arch" type="xml">
            <form string="Promotion">
                <sheet>
                    <group>
                        <field name="tmf_id" readonly="1"/>
                        <field name="href" readonly="1"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="lifecycle_status"/>
                        <field name="promotion_type"/>
                        <field name="partner_id"/>
                        <field name="pricelist_id"/>
                        <field name="pricelist_item_id"/>
                        <field name="last_update" readonly="1"/>
                    </group>

                    <group string="TMF meta">
                        <field name="tmf_type"/>
                        <field name="base_type"/>
                        <field name="schema_location"/>
                    </group>

                    <group string="Structures (JSON)">
                        <field name="valid_for_json" widget="text"/>
                        <field name="pattern_json" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_promotion" model="ir.actions.act_window">
        <field name="name">Promotions</field>
        <field name="res_model">tmf.promotion</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_root_promotion" name="TMF671 Promotion" parent="tmf_product_catalog.menu_tmf_root" sequence="10"/>
    <menuitem id="menu_tmf_promotion" name="Promotion (TMF671)" parent="menu_tmf_root_promotion" sequence="40" action="action_tmf_promotion"/>

</odoo>
