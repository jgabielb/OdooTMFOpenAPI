<odoo>
  <record id="view_tmf_resource_order_form" model="ir.ui.view">
    <field name="name">tmf.resource.order.form</field>
    <field name="model">tmf.resource.order</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="cancellationDate"/>
            <field name="cancellationReason"/>
            <field name="category"/>
            <field name="completionDate"/>
            <field name="description"/>
            <field name="expectedCompletionDate"/>
            <field name="name"/>
            <field name="orderDate"/>
            <field name="orderType"/>
            <field name="priority"/>
            <field name="requestedCompletionDate"/>
            <field name="requestedStartDate"/>
            <field name="startDate"/>
            <field name="state"/>

            <field name="external_reference_ids"/>
            <field name="note_ids"/>
            <field name="order_item_ids"/>
            <field name="related_party_ids"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_tmf_resource_order_tree" model="ir.ui.view">
    <field name="name">tmf.resource.order.tree</field>
    <field name="model">tmf.resource.order</field>
    <field name="arch" type="xml">
      <list>
        <field name="category"/>
        <field name="name"/>
        <field name="priority"/>
        <field name="state"/>
        <field name="orderDate"/>
        <field name="expectedCompletionDate"/>
        <field name="completionDate"/>
      </list>
    </field>
  </record>

  <record id="action_tmf_resource_order" model="ir.actions.act_window">
    <field name="name">Resource Order</field>
    <field name="res_model">tmf.resource.order</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_tmf_resource_order"
            name="Resource Order"
            parent="tmf_base.menu_tmf_root"
            action="action_tmf_resource_order"/>
</odoo>
