<odoo>
    <record id="view_tmf_abstract_environment_tree" model="ir.ui.view">
        <field name="name">tmf.abstract.environment.tree</field>
        <field name="model">tmf.abstract.environment</field>
        <field name="arch" type="xml">
            <list string="AbstractEnvironment">
                <field name="description"/>
                <field name="version"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_abstract_environment_form" model="ir.ui.view">
        <field name="name">tmf.abstract.environment.form</field>
        <field name="model">tmf.abstract.environment</field>
        <field name="arch" type="xml">
            <form string="AbstractEnvironment">
                <sheet>
                    <group>
                        <field name="description"/>
                        <field name="version"/>
                        <field name="state"/>
                        <field name="abstract_environment_definition_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_abstract_environment" model="ir.actions.act_window">
        <field name="name">AbstractEnvironment</field>
        <field name="res_model">tmf.abstract.environment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_abstract_environment" name="AbstractEnvironment" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_abstract_environment"/>

