<odoo>
    <!-- Product Specification Form View -->
    <record id="view_product_specification_form" model="ir.ui.view">
        <field name="name">product.specification.form</field>
        <field name="model">tmf.product.specification</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Button to Activate (Visible only when in Design) -->
                    <button name="action_set_active" 
                            string="Publish / Active" 
                            type="object" 
                            class="oe_highlight"
                            invisible="lifecycle_status != 'design'"/>
                    
                    <!-- Button to Retire (Visible when Active) -->
                    <button name="action_set_retired" 
                            string="Retire" 
                            type="object" 
                            invisible="lifecycle_status != 'active'"/>
                            
                    <!-- Button to Reset (Visible when Retired) -->
                    <button name="action_reset_design" 
                            string="Reset to Design" 
                            type="object" 
                            invisible="lifecycle_status != 'retired'"/>

                    <!-- The Status Bar (Visual Only) -->
                    <field name="lifecycle_status" widget="statusbar" statusbar_visible="design,active,retired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. 5G Data Service"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="brand"/>
                            <field name="product_number"/>
                        </group>
                        <group>
                            <field name="version"/>
                            <field name="tmf_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Technical description..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 3. Product Specification List View -->
    <record id="view_product_specification_tree" model="ir.ui.view">
        <field name="name">product.specification.list</field>
        <field name="model">tmf.product.specification</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_number"/>
                <field name="version"/>
                <field name="lifecycle_status" widget="badge" decoration-success="lifecycle_status == 'active'"/>
            </list>
        </field>
    </record>

    <!-- 4. Action to open Specifications -->
    <record id="action_product_specification" model="ir.actions.act_window">
        <field name="name">Product Specifications</field>
        <field name="res_model">tmf.product.specification</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- 5. Menu Item under the new Root Menu -->
    <menuitem id="menu_product_specification"
              name="Specifications"
              parent="tmf_base.menu_tmf_root"
              action="action_product_specification"
              sequence="10"/>

    <!-- ======================================================= -->
    <!-- EXTEND STANDARD PRODUCT FORM (To link Spec to Offering) -->
    <!-- ======================================================= -->
    <record id="product_template_tmf_form_view" model="ir.ui.view">
        <field name="name">product.template.tmf.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="product_specification_id"/>
                <field name="lifecycle_status"/>
                <field name="tmf_id" readonly="1" groups="base.group_no_one"/>
            </xpath>
        </field>
    </record>
</odoo>
