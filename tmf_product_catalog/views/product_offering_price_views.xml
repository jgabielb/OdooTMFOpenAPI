<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_tmf_product_offering_price_list" model="ir.ui.view">
    <field name="name">tmf.product.offering.price.list</field>
    <field name="model">tmf.product.offering.price</field>
    <field name="arch" type="xml">
      <list string="Product Offering Prices">
        <field name="name"/>
        <field name="price_type"/>
        <field name="lifecycle_status"/>
        <field name="version"/>
        <field name="offering_id"/>
        <field name="tmf_id"/>
      </list>
    </field>
  </record>

  <record id="view_tmf_product_offering_price_form" model="ir.ui.view">
    <field name="name">tmf.product.offering.price.form</field>
    <field name="model">tmf.product.offering.price</field>
    <field name="arch" type="xml">
      <form string="Product Offering Price">
        <sheet>
          <group>
            <field name="name"/>
            <field name="price_type"/>
            <field name="lifecycle_status"/>
            <field name="version"/>
            <field name="offering_id"/>
          </group>
          <group string="Description">
            <field name="description" colspan="2"/>
          </group>
          <group string="Price">
            <field name="price_json" widget="json" colspan="4"/>
          </group>
          <group string="TMF Metadata">
            <field name="tmf_id" readonly="1"/>
            <field name="href" readonly="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_tmf_product_offering_price" model="ir.actions.act_window">
    <field name="name">Product Offering Prices</field>
    <field name="res_model">tmf.product.offering.price</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_tmf_product_offering_price"
            name="Offering Prices"
            parent="tmf_base.menu_tmf_root"
            action="action_tmf_product_offering_price"
            sequence="20"/>

</odoo>
