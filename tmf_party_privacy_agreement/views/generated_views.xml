<odoo>
    <record id="view_tmf_party_privacy_agreement_form" model="ir.ui.view">
        <field name="name">tmf.party.privacy.agreement.form</field>
        <field name="model">tmf.party.privacy.agreement</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="agreement_type"/>
                <field name="description"/>
                <field name="document_number"/>
                <field name="initial_date"/>
                <field name="name"/>
                <field name="statement_of_intent"/>
                <field name="status"/>
                <field name="version"/>
                <field name="agreement_authorization"/>
                <field name="agreement_item"/>
                <field name="agreement_period"/>
                <field name="agreement_specification"/>
                <field name="associated_agreement"/>
                <field name="characteristic"/>
                <field name="completion_date"/>
                <field name="engaged_party"/>
                <field name="party_privacy_profile"/>
                <field name="party_privacy_profile_characteristic"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_party_privacy_agreement_tree" model="ir.ui.view">
        <field name="name">tmf.party.privacy.agreement.tree</field>
        <field name="model">tmf.party.privacy.agreement</field>
        <field name="arch" type="xml">
            <list>
                <field name="agreement_type"/>
                <field name="description"/>
                <field name="document_number"/>
                <field name="initial_date"/>
                <field name="name"/>
                <field name="statement_of_intent"/>
                <field name="status"/>
                <field name="version"/>
                <field name="agreement_authorization"/>
                <field name="agreement_item"/>
                <field name="agreement_period"/>
                <field name="agreement_specification"/>
                <field name="associated_agreement"/>
                <field name="characteristic"/>
                <field name="completion_date"/>
                <field name="engaged_party"/>
                <field name="party_privacy_profile"/>
                <field name="party_privacy_profile_characteristic"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_party_privacy_agreement" model="ir.actions.act_window">
        <field name="name">PartyPrivacyAgreement</field>
        <field name="res_model">tmf.party.privacy.agreement</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_party_privacy_agreement"
              name="PartyPrivacyAgreement"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_party_privacy_agreement"/>
</odoo>
