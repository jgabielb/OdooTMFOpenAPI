<odoo>
    <!-- FORM VIEW -->
    <record id="view_tmf_appointment_form" model="ir.ui.view">
        <field name="name">tmf.appointment.form</field>
        <field name="model">tmf.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="category" class="oe_edit_only"/>
                        <h1><field name="category" placeholder="e.g. Installation"/></h1>
                    </div>
                    <group>
                        <group string="Schedule">
                            <!-- These match the Python fields defined in Step 2 -->
                            <field name="valid_for_start" string="Start Date"/>
                            <field name="valid_for_end" string="End Date"/>
                            <field name="external_id"/>
                            <field name="partner_id"/>
                            <field name="calendar_event_id"/>
                        </group>
                        <group string="System Data">
                            <field name="creation_date" readonly="1"/>
                            <field name="last_update" readonly="1"/>
                            <field name="tmf_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description..."/>
                    
                    <notebook>
                        <page string="Details">
                            <group>
                                <field name="contact_medium"/>
                                <field name="note"/>
                                <field name="attachment"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_tmf_appointment_tree" model="ir.ui.view">
        <field name="name">tmf.appointment.tree</field>
        <field name="model">tmf.appointment</field>
        <field name="arch" type="xml">
            <list>
                <field name="category"/>
                <field name="description"/>
                <field name="status" widget="badge"/>
                <field name="valid_for_start"/>
                <field name="valid_for_end"/>
                <field name="partner_id"/>
                <field name="calendar_event_id"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_tmf_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">tmf.appointment</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU: FIXED PARENT (Under Main TMF App, NOT Billing) -->
    <menuitem id="menu_tmf_appointment"
              name="Appointment"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_appointment"
              sequence="60"/>
</odoo>
