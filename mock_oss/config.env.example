# Mock OSS Simulator — Environment Variables
# Copy this file to config.env and adjust values as needed.

# Odoo base URL (from inside Docker, use host.docker.internal for localhost)
ODOO_BASE_URL=http://host.docker.internal:8069

# API key for X-API-Key header authentication (leave empty to skip)
ODOO_API_KEY=

# Polling interval in seconds (how often to check for services to advance)
POLL_INTERVAL=15

# Delay in seconds between individual state transitions (simulates OSS processing)
STEP_DELAY=5

# Set to "true" to log transitions without actually PATCHing
DRY_RUN=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
