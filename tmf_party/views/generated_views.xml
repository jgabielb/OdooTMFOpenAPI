<odoo>
    <record id="view_tmf_party_form" model="ir.ui.view">
        <field name="name">tmf.party.form</field>
        <field name="model">tmf.party</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="contact_medium"/>
                <field name="credit_rating"/>
                <field name="external_reference"/>
                <field name="party_characteristic"/>
                <field name="related_party"/>
                <field name="tax_exemption_certificate"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_party_tree" model="ir.ui.view">
        <field name="name">tmf.party.tree</field>
        <field name="model">tmf.party</field>
        <field name="arch" type="xml">
            <list>
                <field name="contact_medium"/>
                <field name="credit_rating"/>
                <field name="external_reference"/>
                <field name="party_characteristic"/>
                <field name="related_party"/>
                <field name="tax_exemption_certificate"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_party" model="ir.actions.act_window">
        <field name="name">Party</field>
        <field name="res_model">tmf.party</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_party"
              name="Party"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_party"/>
</odoo>
