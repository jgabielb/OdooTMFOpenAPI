<odoo>
    <record id="view_tmf_check_work_qualification_tree" model="ir.ui.view">
        <field name="name">tmf.check.work.qualification.tree</field>
        <field name="model">tmf.check.work.qualification</field>
        <field name="arch" type="xml">
            <list string="Check Work Qualification">
                <field name="tmf_id"/>
                <field name="description"/>
                <field name="external_id"/>
                <field name="state"/>
                <field name="qualification_result"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_check_work_qualification_form" model="ir.ui.view">
        <field name="name">tmf.check.work.qualification.form</field>
        <field name="model">tmf.check.work.qualification</field>
        <field name="arch" type="xml">
            <form string="Check Work Qualification">
                <sheet>
                    <group>
                        <field name="description"/>
                        <field name="external_id"/>
                        <field name="state"/>
                        <field name="expected_qualification_date"/>
                        <field name="effective_qualification_date"/>
                        <field name="estimated_response_date"/>
                        <field name="expiration_date"/>
                        <field name="instant_sync_qualification"/>
                        <field name="check_work_qualification_date"/>
                        <field name="qualification_result"/>
                        <field name="provide_alternative"/>
                        <field name="provide_unavailability_reason"/>
                    </group>
                    <group>
                        <field name="work_qualification_item_json"/>
                        <field name="place_json"/>
                        <field name="related_party_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_check_work_qualification" model="ir.actions.act_window">
        <field name="name">Check Work Qualification</field>
        <field name="res_model">tmf.check.work.qualification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_check_work_qualification" name="Check Work Qualification" parent="tmf_base.menu_tmf_root" action="action_tmf_check_work_qualification"/>

    <record id="view_tmf_query_work_qualification_tree" model="ir.ui.view">
        <field name="name">tmf.query.work.qualification.tree</field>
        <field name="model">tmf.query.work.qualification</field>
        <field name="arch" type="xml">
            <list string="Query Work Qualification">
                <field name="tmf_id"/>
                <field name="description"/>
                <field name="external_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_query_work_qualification_form" model="ir.ui.view">
        <field name="name">tmf.query.work.qualification.form</field>
        <field name="model">tmf.query.work.qualification</field>
        <field name="arch" type="xml">
            <form string="Query Work Qualification">
                <sheet>
                    <group>
                        <field name="description"/>
                        <field name="external_id"/>
                        <field name="state"/>
                        <field name="expected_qualification_date"/>
                        <field name="effective_qualification_date"/>
                        <field name="estimated_response_date"/>
                        <field name="expiration_date"/>
                        <field name="instant_sync_qualification"/>
                        <field name="query_work_qualification_date"/>
                    </group>
                    <group>
                        <field name="search_criteria_json"/>
                        <field name="work_qualification_item_json"/>
                        <field name="place_json"/>
                        <field name="related_party_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_query_work_qualification" model="ir.actions.act_window">
        <field name="name">Query Work Qualification</field>
        <field name="res_model">tmf.query.work.qualification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_query_work_qualification" name="Query Work Qualification" parent="tmf_base.menu_tmf_root" action="action_tmf_query_work_qualification"/>
</odoo>
