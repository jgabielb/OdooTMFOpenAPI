<odoo>
    <record id="view_tmf_cloud_application_tree" model="ir.ui.view">
        <field name="name">tmf.cloud.application.tree</field>
        <field name="model">tmf.cloud.application</field>
        <field name="arch" type="xml">
            <list string="CloudApplication">
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="operational_state"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_cloud_application_form" model="ir.ui.view">
        <field name="name">tmf.cloud.application.form</field>
        <field name="model">tmf.cloud.application</field>
        <field name="arch" type="xml">
            <form string="CloudApplication">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="operational_state"/>
                    </group>
                    <group>
                        <field name="payload_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_cloud_application" model="ir.actions.act_window">
        <field name="name">Platform Cloud Application</field>
        <field name="res_model">tmf.cloud.application</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_cloud_application" name="Platform Cloud Application" parent="tmf_base.menu_tmf_root" action="action_tmf_cloud_application"/>

