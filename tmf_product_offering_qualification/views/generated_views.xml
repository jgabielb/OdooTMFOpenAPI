<odoo>
    <record id="view_tmf_product_offering_qualification_form" model="ir.ui.view">
        <field name="name">tmf.product.offering.qualification.form</field>
        <field name="model">tmf.product.offering.qualification</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="effective_qualification_date"/>
                <field name="expected_poq_completion_date"/>
                <field name="instant_sync_qualification"/>
                <field name="project_id"/>
                <field name="provide_alternative"/>
                <field name="requested_poq_completion_date"/>
                <field name="product_offering_qualification_item"/>
                <field name="related_party"/>
                <field name="state"/>
                <field name="state_change"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_product_offering_qualification_tree" model="ir.ui.view">
        <field name="name">tmf.product.offering.qualification.tree</field>
        <field name="model">tmf.product.offering.qualification</field>
        <field name="arch" type="xml">
            <list>
                <field name="effective_qualification_date"/>
                <field name="expected_poq_completion_date"/>
                <field name="instant_sync_qualification"/>
                <field name="project_id"/>
                <field name="provide_alternative"/>
                <field name="requested_poq_completion_date"/>
                <field name="product_offering_qualification_item"/>
                <field name="related_party"/>
                <field name="state"/>
                <field name="state_change"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_product_offering_qualification" model="ir.actions.act_window">
        <field name="name">ProductOfferingQualification</field>
        <field name="res_model">tmf.product.offering.qualification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_product_offering_qualification"
              name="ProductOfferingQualification"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_product_offering_qualification"/>
</odoo>
