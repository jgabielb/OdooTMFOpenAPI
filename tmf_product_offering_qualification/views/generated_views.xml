<odoo>
    <!-- Main Model Form -->
    <record id="view_tmf_check_poq_form" model="ir.ui.view">
        <field name="name">tmf.check.poq.form</field>
        <field name="model">tmf.check.product.offering.qualification</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="tmf_id" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="effective_qualification_date"/>
                            <field name="qualification_result"/>
                            <field name="tmf_type" invisible="1"/>
                        </group>
                        <group>
                            <field name="create_date" string="Creation Date" readonly="1"/>
                            <field name="description"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Qualification Items">
                            <field name="item_ids">
                                <list editable="bottom">
                                    <field name="tmf_id"/>
                                    <field name="product_json"/>
                                    <field name="qualification_item_result"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Related Parties">
                            <field name="related_party_json"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Main Model Tree -->
    <record id="view_tmf_check_poq_tree" model="ir.ui.view">
        <field name="name">tmf.check.poq.tree</field>
        <field name="model">tmf.check.product.offering.qualification</field>
        <field name="arch" type="xml">
            <list>
                <field name="tmf_id"/>
                <field name="create_date"/>
                <field name="effective_qualification_date"/>
                <field name="qualification_result"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_check_poq" model="ir.actions.act_window">
        <field name="name">Check Product Offering Qualification</field>
        <field name="res_model">tmf.check.product.offering.qualification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_check_poq" name="Product Offering Qualification" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_check_poq"/>
</odoo>