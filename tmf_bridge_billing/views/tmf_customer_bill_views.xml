<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Add a "Rebuild TMFC031 Wiring" button to the bill form header -->
    <record id="view_tmf_customer_bill_form_rebuild_wiring" model="ir.ui.view">
        <field name="name">tmf.customer.bill.form.rebuild.wiring</field>
        <field name="model">tmf.customer.bill</field>
        <field name="inherit_id" ref="tmf_customer_bill_management.view_tmf_customer_bill_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_rebuild_tmfc031_wiring"
                            type="object"
                            string="Rebuild TMFC031 Wiring"
                            class="oe_highlight"
                            help="Reconstruct payload + resolve cross-API refs from move_id -> sale.order -> tmf.service"/>
                </header>
            </xpath>
        </field>
    </record>

    <!-- Server action so it can also be triggered in bulk from the list view -->
    <record id="action_rebuild_tmfc031_wiring_bulk" model="ir.actions.server">
        <field name="name">Rebuild TMFC031 Wiring (bulk)</field>
        <field name="model_id" ref="tmf_customer_bill_management.model_tmf_customer_bill"/>
        <field name="binding_model_id" ref="tmf_customer_bill_management.model_tmf_customer_bill"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_rebuild_tmfc031_wiring()</field>
    </record>

</odoo>
