<odoo>
    <record id="view_tmf_resource_catalog_form" model="ir.ui.view">
        <field name="name">tmf.resource.catalog.form</field>
        <field name="model">tmf.resource.catalog</field>
        <field name="arch" type="xml">
            <form string="Resource Catalog">
                <sheet>
                    <group>
                        <field name="name" required="1"/>
                        <field name="description"/>
                        <field name="version"/>
                        <field name="product_tmpl_id"/>
                        <field name="lifecycle_status"/>
                        <field name="last_update"/>
                    </group>

                    <group string="TMF Structures">
                        <!-- TMF634 expects arrays/objects (category[], relatedParty[], validFor{}) -->
                        <field name="category_json" widget="json"/>
                        <field name="related_party_json" widget="json"/>
                        <field name="valid_for_json" widget="json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_resource_catalog_tree" model="ir.ui.view">
        <field name="name">tmf.resource.catalog.tree</field>
        <field name="model">tmf.resource.catalog</field>
        <field name="arch" type="xml">
            <list string="Resource Catalogs">
                <field name="name"/>
                <field name="version"/>
                <field name="product_tmpl_id"/>
                <field name="lifecycle_status"/>
                <field name="last_update"/>
                <field name="description"/>
                <!-- Keep JSON fields visible for debugging; remove if you prefer -->
                <field name="category_json"/>
                <field name="related_party_json"/>
                <field name="valid_for_json"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_resource_catalog" model="ir.actions.act_window">
        <field name="name">ResourceCatalog</field>
        <field name="res_model">tmf.resource.catalog</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_resource_catalog"
              name="ResourceCatalog"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_resource_catalog"/>
</odoo>
