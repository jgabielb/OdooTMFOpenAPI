<odoo>
    <record id="view_tmf_party_role_product_offering_risk_assessment_form" model="ir.ui.view">
        <field name="name">tmf.party.role.product.offering.risk.assessment.form</field>
        <field name="model">tmf.party.role.product.offering.risk.assessment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="status"/>
                <field name="characteristic"/>
                <field name="party_role"/>
                <field name="place"/>
                <field name="product_offering"/>
                <field name="risk_assessment_result"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_party_role_product_offering_risk_assessment_tree" model="ir.ui.view">
        <field name="name">tmf.party.role.product.offering.risk.assessment.tree</field>
        <field name="model">tmf.party.role.product.offering.risk.assessment</field>
        <field name="arch" type="xml">
            <list>
                <field name="status"/>
                <field name="characteristic"/>
                <field name="party_role"/>
                <field name="place"/>
                <field name="product_offering"/>
                <field name="risk_assessment_result"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_party_role_product_offering_risk_assessment" model="ir.actions.act_window">
        <field name="name">Party Role Product Offering Risk Assessment</field>
        <field name="res_model">tmf.party.role.product.offering.risk.assessment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_party_role_product_offering_risk_assessment"
              name="Party Role Product Offering Risk Assessment"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_party_role_product_offering_risk_assessment"/>
</odoo>
