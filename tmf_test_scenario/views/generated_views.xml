<odoo>
    <record id="view_tmf_test_scenario_form" model="ir.ui.view">
        <field name="name">tmf.test.scenario.form</field>
        <field name="model">tmf.test.scenario</field>
        <field name="arch" type="xml">
            <form string="TestScenario">
                <sheet>
                    <group>
                        <field name="description"/>
                        <field name="version"/>
                        <field name="version_description"/>
                        <field name="state"/>
                        <field name="agreement_json"/>
                        <field name="attribute_json"/>
                        <field name="related_party_json"/>
                        <field name="test_scenario_definition_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_test_scenario_tree" model="ir.ui.view">
        <field name="name">tmf.test.scenario.tree</field>
        <field name="model">tmf.test.scenario</field>
        <field name="arch" type="xml">
            <list string="TestScenario">
                <field name="tmf_id"/>
                <field name="description"/>
                <field name="version"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_test_scenario" model="ir.actions.act_window">
        <field name="name">TestScenario</field>
        <field name="res_model">tmf.test.scenario</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_test_scenario"
              name="TestScenario"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_test_scenario"/>
</odoo>
