<odoo>
    <record id="view_tmf_test_case_result_tree" model="ir.ui.view">
        <field name="name">tmf.test.case.result.tree</field>
        <field name="model">tmf.test.case.result</field>
        <field name="arch" type="xml">
            <list string="TestCaseResult">
                <field name="tmf_id"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_test_case_result_form" model="ir.ui.view">
        <field name="name">tmf.test.case.result.form</field>
        <field name="model">tmf.test.case.result</field>
        <field name="arch" type="xml">
            <form string="TestCaseResult">
                <sheet>
                    <group>
                        <field name="test_execution_json"/>
                        <field name="test_case_result_definition_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_test_case_result" model="ir.actions.act_window">
        <field name="name">TestCaseResult</field>
        <field name="res_model">tmf.test.case.result</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_test_case_result" name="TestCaseResult" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_test_case_result"/>

