<odoo>
    <record id="view_tmf_shipment_tracking_form" model="ir.ui.view">
        <field name="name">tmf.shipment.tracking.form</field>
        <field name="model">tmf.shipment.tracking</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="tracking_number"/>
                        <field name="status"/>
                        <field name="partner_id"/>
                        <field name="picking_id"/>
                        <field name="estimated_delivery_date"/>
                        <field name="actual_delivery_date"/>
                        <field name="last_update"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_shipment_tracking_list" model="ir.ui.view">
        <field name="name">tmf.shipment.tracking.list</field>
        <field name="model">tmf.shipment.tracking</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="tracking_number"/>
                <field name="status"/>
                <field name="partner_id"/>
                <field name="picking_id"/>
                <field name="last_update"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_shipment_tracking" model="ir.actions.act_window">
        <field name="name">ShipmentTracking</field>
        <field name="res_model">tmf.shipment.tracking</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_shipment_tracking"
              name="ShipmentTracking"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_shipment_tracking"/>
</odoo>

