<odoo>
    <record id="view_tmf_service_usage_tree" model="ir.ui.view">
        <field name="name">tmf.service.usage.tree</field>
        <field name="model">tmf.service.usage</field>
        <field name="arch" type="xml">
            <list string="Service Usage">
                <field name="tmf_id"/>
                <field name="status"/>
                <field name="usage_type"/>
                <field name="usage_date"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_service_usage_form" model="ir.ui.view">
        <field name="name">tmf.service.usage.form</field>
        <field name="model">tmf.service.usage</field>
        <field name="arch" type="xml">
            <form string="Service Usage">
                <sheet>
                    <group>
                        <field name="status"/>
                        <field name="usage_type"/>
                        <field name="usage_date"/>
                        <field name="description"/>
                    </group>
                    <group>
                        <field name="service_json"/>
                        <field name="usage_specification_json"/>
                        <field name="related_party_json"/>
                        <field name="usage_characteristic_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_service_usage" model="ir.actions.act_window">
        <field name="name">Service Usage</field>
        <field name="res_model">tmf.service.usage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_service_usage" name="Service Usage" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_service_usage"/>
</odoo>
