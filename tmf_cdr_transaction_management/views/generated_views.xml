<odoo>
    <record id="view_tmf_cdr_transaction_tree" model="ir.ui.view">
        <field name="name">tmf.cdr.transaction.tree</field>
        <field name="model">tmf.cdr.transaction</field>
        <field name="arch" type="xml">
            <list string="CdrTransaction">
                <field name="tmf_id"/>
                <field name="state"/>
                <field name="requested_initial_state"/>
                <field name="creation_date"/>
                <field name="completion_date"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_cdr_transaction_form" model="ir.ui.view">
        <field name="name">tmf.cdr.transaction.form</field>
        <field name="model">tmf.cdr.transaction</field>
        <field name="arch" type="xml">
            <form string="CdrTransaction">
                <sheet>
                    <group>
                        <field name="state"/>
                        <field name="requested_initial_state"/>
                        <field name="creation_date"/>
                        <field name="completion_date"/>
                        <field name="cancellation_date"/>
                        <field name="cancellation_reason"/>
                        <field name="description"/>
                    </group>
                    <group>
                        <field name="related_party_json"/>
                        <field name="channel_json"/>
                        <field name="transaction_item_json"/>
                        <field name="note_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_cdr_transaction" model="ir.actions.act_window">
        <field name="name">CDR Transaction</field>
        <field name="res_model">tmf.cdr.transaction</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_cdr_transaction" name="CDR Transaction" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_cdr_transaction"/>
</odoo>
