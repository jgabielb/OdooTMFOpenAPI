<odoo>
    <record id="view_tmf_test_data_instance_tree" model="ir.ui.view">
        <field name="name">tmf.test.data.instance.tree</field>
        <field name="model">tmf.test.data.instance</field>
        <field name="arch" type="xml">
            <list string="TestDataInstance">
                <field name="description"/>
                <field name="version"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_test_data_instance_form" model="ir.ui.view">
        <field name="name">tmf.test.data.instance.form</field>
        <field name="model">tmf.test.data.instance</field>
        <field name="arch" type="xml">
            <form string="TestDataInstance">
                <sheet>
                    <group>
                        <field name="description"/>
                        <field name="version"/>
                        <field name="state"/>
                        <field name="test_data_instance_definition_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_test_data_instance" model="ir.actions.act_window">
        <field name="name">TestDataInstance</field>
        <field name="res_model">tmf.test.data.instance</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_test_data_instance" name="TestDataInstance" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_test_data_instance"/>

    <record id="view_tmf_test_data_schema_tree" model="ir.ui.view">
        <field name="name">tmf.test.data.schema.tree</field>
        <field name="model">tmf.test.data.schema</field>
        <field name="arch" type="xml">
            <list string="TestDataSchema">
                <field name="description"/>
                <field name="version"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_test_data_schema_form" model="ir.ui.view">
        <field name="name">tmf.test.data.schema.form</field>
        <field name="model">tmf.test.data.schema</field>
        <field name="arch" type="xml">
            <form string="TestDataSchema">
                <sheet>
                    <group>
                        <field name="description"/>
                        <field name="version"/>
                        <field name="state"/>
                        <field name="test_data_schema_definition_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_test_data_schema" model="ir.actions.act_window">
        <field name="name">TestDataSchema</field>
        <field name="res_model">tmf.test.data.schema</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_test_data_schema" name="TestDataSchema" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_test_data_schema"/>
</odoo>
