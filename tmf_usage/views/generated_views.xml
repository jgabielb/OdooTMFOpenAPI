<odoo>
    <record id="view_tmf_usage_form" model="ir.ui.view">
        <field name="name">tmf.usage.form</field>
        <field name="model">tmf.usage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="description"/>
                <field name="usage_date"/>
                <field name="usage_type"/>
                <field name="rated_product_usage"/>
                <field name="related_party"/>
                <field name="status"/>
                <field name="usage_characteristic"/>
                <field name="usage_specification"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_usage_tree" model="ir.ui.view">
        <field name="name">tmf.usage.tree</field>
        <field name="model">tmf.usage</field>
        <field name="arch" type="xml">
            <list>
                <field name="description"/>
                <field name="usage_date"/>
                <field name="usage_type"/>
                <field name="rated_product_usage"/>
                <field name="related_party"/>
                <field name="status"/>
                <field name="usage_characteristic"/>
                <field name="usage_specification"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_usage" model="ir.actions.act_window">
        <field name="name">Usage</field>
        <field name="res_model">tmf.usage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_usage"
              name="Usage"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_usage"/>
</odoo>
