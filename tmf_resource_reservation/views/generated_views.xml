<odoo>
    <record id="view_tmf_resource_reservation_tree" model="ir.ui.view">
        <field name="name">tmf.resource.reservation.tree</field>
        <field name="model">tmf.resource.reservation</field>
        <field name="arch" type="xml">
            <list string="Resource Reservation">
                <field name="tmf_id"/>
                <field name="description"/>
                <field name="state"/>
                <field name="requested_start_date"/>
                <field name="requested_completion_date"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_resource_reservation_form" model="ir.ui.view">
        <field name="name">tmf.resource.reservation.form</field>
        <field name="model">tmf.resource.reservation</field>
        <field name="arch" type="xml">
            <form string="Resource Reservation">
                <sheet>
                    <group>
                        <field name="description"/>
                        <field name="state"/>
                        <field name="creation_date"/>
                        <field name="requested_start_date"/>
                        <field name="requested_completion_date"/>
                        <field name="expected_completion_date"/>
                        <field name="completion_date"/>
                    </group>
                    <group>
                        <field name="reservation_item_json"/>
                        <field name="reservation_period_json"/>
                        <field name="related_entity_json"/>
                        <field name="related_party_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_resource_reservation" model="ir.actions.act_window">
        <field name="name">Resource Reservation</field>
        <field name="res_model">tmf.resource.reservation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_resource_reservation" name="Resource Reservation" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_resource_reservation"/>

    <record id="view_tmf_cancel_resource_reservation_tree" model="ir.ui.view">
        <field name="name">tmf.cancel.resource.reservation.tree</field>
        <field name="model">tmf.cancel.resource.reservation</field>
        <field name="arch" type="xml">
            <list string="Cancel Resource Reservation">
                <field name="tmf_id"/>
                <field name="state"/>
                <field name="cancellation_reason"/>
                <field name="requested_cancellation_date"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_cancel_resource_reservation_form" model="ir.ui.view">
        <field name="name">tmf.cancel.resource.reservation.form</field>
        <field name="model">tmf.cancel.resource.reservation</field>
        <field name="arch" type="xml">
            <form string="Cancel Resource Reservation">
                <sheet>
                    <group>
                        <field name="state"/>
                        <field name="cancellation_reason"/>
                        <field name="requested_cancellation_date"/>
                        <field name="effective_cancellation_date"/>
                    </group>
                    <group>
                        <field name="resource_reservation_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_cancel_resource_reservation" model="ir.actions.act_window">
        <field name="name">Cancel Resource Reservation</field>
        <field name="res_model">tmf.cancel.resource.reservation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_cancel_resource_reservation" name="Cancel Resource Reservation" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_cancel_resource_reservation"/>
</odoo>
