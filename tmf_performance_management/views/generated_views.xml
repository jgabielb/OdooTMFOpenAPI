<odoo>
    <record id="view_tmf_performance_management_resource_form" model="ir.ui.view">
        <field name="name">tmf.performance.management.resource.form</field>
        <field name="model">tmf.performance.management.resource</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="resource_type"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="status"/>
                        <field name="state"/>
                        <field name="lifecycle_status"/>
                        <field name="tmf_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_performance_management_resource_list" model="ir.ui.view">
        <field name="name">tmf.performance.management.resource.list</field>
        <field name="model">tmf.performance.management.resource</field>
        <field name="arch" type="xml">
            <list>
                <field name="resource_type"/>
                <field name="name"/>
                <field name="status"/>
                <field name="state"/>
                <field name="lifecycle_status"/>
                <field name="tmf_id"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_performance_management_resource" model="ir.actions.act_window">
        <field name="name">TMF628 Performance</field>
        <field name="res_model">tmf.performance.management.resource</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_performance_management_resource"
              name="TMF628 Performance"
              parent="tmf_base.menu_tmf_root"
              action="action_tmf_performance_management_resource"/>
</odoo>
