<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_tmf_account" model="ir.ui.view">
        <field name="name">sale.order.tmf.account</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="tmf_account_id"
                       options="{'no_create': False}"
                       context="{'default_partner_id': partner_id, 'default_resource_type': 'PartyAccount'}"/>
            </xpath>
        </field>
    </record>
</odoo>
