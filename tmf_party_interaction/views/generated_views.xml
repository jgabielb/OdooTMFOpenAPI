<odoo>
    <record id="view_tmf_party_interaction_form" model="ir.ui.view">
        <field name="name">tmf.party.interaction.form</field>
        <field name="model">tmf.party.interaction</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="creation_date"/>
                <field name="description"/>
                <field name="direction"/>
                <field name="reason"/>
                <field name="status"/>
                <field name="status_change_date"/>
                <field name="attachment"/>
                <field name="channel"/>
                <field name="interaction_date"/>
                <field name="interaction_item"/>
                <field name="interaction_relationship"/>
                <field name="note"/>
                <field name="related_party"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_party_interaction_tree" model="ir.ui.view">
        <field name="name">tmf.party.interaction.tree</field>
        <field name="model">tmf.party.interaction</field>
        <field name="arch" type="xml">
            <list>
                <field name="creation_date"/>
                <field name="description"/>
                <field name="direction"/>
                <field name="reason"/>
                <field name="status"/>
                <field name="status_change_date"/>
                <field name="attachment"/>
                <field name="channel"/>
                <field name="interaction_date"/>
                <field name="interaction_item"/>
                <field name="interaction_relationship"/>
                <field name="note"/>
                <field name="related_party"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_party_interaction" model="ir.actions.act_window">
        <field name="name">PartyInteraction</field>
        <field name="res_model">tmf.party.interaction</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_party_interaction"
              name="PartyInteraction"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_party_interaction"/>
</odoo>
