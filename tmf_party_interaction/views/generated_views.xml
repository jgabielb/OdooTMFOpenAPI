<odoo>
    <!-- FORM -->
    <record id="view_tmf_party_interaction_form" model="ir.ui.view">
        <field name="name">tmf.party.interaction.form</field>
        <field name="model">tmf.party.interaction</field>
        <field name="arch" type="xml">
            <form string="Party Interaction">
                <sheet>
                    <group>
                        <field name="tmf_id" readonly="1"/>
                        <field name="href" readonly="1"/>
                        <field name="tmf_type" readonly="1"/>

                        <field name="creation_date"/>
                        <field name="interaction_date"/>
                        <field name="status"/>
                        <field name="status_change_date"/>

                        <field name="direction"/>
                        <field name="reason"/>
                        <field name="description"/>
                    </group>

                    <notebook>
                        <page string="Related Channel">
                            <group>
                                <field name="related_channel" widget="json" options="{'mode': 'tree'}"/>
                            </group>
                        </page>
                        <page string="Related Party">
                            <group>
                                <field name="related_party" widget="json" options="{'mode': 'tree'}"/>
                            </group>
                        </page>
                        <page string="Items / Relationships">
                            <group>
                                <field name="interaction_item" widget="json" options="{'mode': 'tree'}"/>
                                <field name="interaction_relationship" widget="json" options="{'mode': 'tree'}"/>
                            </group>
                        </page>
                        <page string="Attachments / Notes">
                            <group>
                                <field name="attachment" widget="json" options="{'mode': 'tree'}"/>
                                <field name="note" widget="json" options="{'mode': 'tree'}"/>
                                <field name="external_identifier" widget="json" options="{'mode': 'tree'}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST -->
    <record id="view_tmf_party_interaction_list" model="ir.ui.view">
        <field name="name">tmf.party.interaction.list</field>
        <field name="model">tmf.party.interaction</field>
        <field name="arch" type="xml">
            <list string="Party Interactions">
                <field name="tmf_id"/>
                <field name="direction"/>
                <field name="reason"/>
                <field name="status"/>
                <field name="creation_date"/>
                <field name="interaction_date"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_tmf_party_interaction" model="ir.actions.act_window">
        <field name="name">Party Interaction</field>
        <field name="res_model">tmf.party.interaction</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_tmf_party_interaction"
              name="Party Interaction"
              parent="tmf_base.menu_tmf_root"
              action="action_tmf_party_interaction"/>
</odoo>
