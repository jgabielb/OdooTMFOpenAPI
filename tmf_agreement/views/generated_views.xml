<odoo>
    <record id="view_tmf_agreement_form" model="ir.ui.view">
        <field name="name">tmf.agreement.form</field>
        <field name="model">tmf.agreement</field>
        <field name="arch" type="xml">
            <form string="Agreement">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="agreement_type"/>
                        <field name="status"/>
                        <field name="version"/>
                    </group>

                    <group string="Dates">
                        <field name="initial_date"/>
                        <field name="completion_date"/>
                        <field name="document_number"/>
                    </group>

                    <group string="Details">
                        <field name="description"/>
                        <field name="statement_of_intent"/>
                    </group>

                    <group string="TMF Structures">
                        <field name="engaged_party"/>
                        <field name="agreement_item"/>
                        <field name="agreement_period"/>
                        <field name="agreement_specification"/>
                        <field name="associated_agreement"/>
                        <field name="agreement_authorization"/>
                        <field name="characteristic"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_agreement_tree" model="ir.ui.view">
        <field name="name">tmf.agreement.tree</field>
        <field name="model">tmf.agreement</field>
        <field name="arch" type="xml">
            <list string="Agreements">
                <field name="name"/>
                <field name="agreement_type"/>
                <field name="status"/>
                <field name="version"/>
                <field name="document_number"/>
                <field name="initial_date"/>
                <field name="completion_date"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_agreement" model="ir.actions.act_window">
        <field name="name">Agreement</field>
        <field name="res_model">tmf.agreement</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_agreement"
              name="Agreement"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_agreement"/>
</odoo>
