<odoo>
    <record id="view_tmf_party_rev_sharing_model_tree" model="ir.ui.view">
        <field name="name">tmf.party.rev.sharing.model.tree</field>
        <field name="model">tmf.party.rev.sharing.model</field>
        <field name="arch" type="xml">
            <list string="PartyRevSharingModel">
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="description"/>
                <field name="state"/>
                <field name="lifecycle_status"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_party_rev_sharing_model_form" model="ir.ui.view">
        <field name="name">tmf.party.rev.sharing.model.form</field>
        <field name="model">tmf.party.rev.sharing.model</field>
        <field name="arch" type="xml">
            <form string="PartyRevSharingModel">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="state"/>
                        <field name="lifecycle_status"/>
                    </group>
                    <group>
                        <field name="related_party_json"/>
                        <field name="party_rev_sharing_model_item_json"/>
                        <field name="product_specification_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_party_rev_sharing_model" model="ir.actions.act_window">
        <field name="name">Revenue Sharing Model</field>
        <field name="res_model">tmf.party.rev.sharing.model</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_party_rev_sharing_model" name="Revenue Sharing Model" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_party_rev_sharing_model"/>
</odoo>
