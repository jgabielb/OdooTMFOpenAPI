<odoo>
    <record id="view_tmf_product_stock_relationship_form" model="ir.ui.view">
        <field name="name">tmf.product.stock.relationship.form</field>
        <field name="model">tmf.product.stock.relationship</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="relationship_type"/>
                <field name="stock_level"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_product_stock_relationship_tree" model="ir.ui.view">
        <field name="name">tmf.product.stock.relationship.tree</field>
        <field name="model">tmf.product.stock.relationship</field>
        <field name="arch" type="xml">
            <list>
                <field name="relationship_type"/>
                <field name="stock_level"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_product_stock_relationship" model="ir.actions.act_window">
        <field name="name">ProductStockRelationship</field>
        <field name="res_model">tmf.product.stock.relationship</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_product_stock_relationship"
              name="ProductStockRelationship"
              action="action_tmf_product_stock_relationship"/>
</odoo>
