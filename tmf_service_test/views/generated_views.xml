<odoo>
    <record id="view_tmf_service_test_form" model="ir.ui.view">
        <field name="name">tmf.service.test.form</field>
        <field name="model">tmf.service.test</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="description"/>
                <field name="end_date_time"/>
                <field name="mode"/>
                <field name="name"/>
                <field name="start_date_time"/>
                <field name="state"/>
                <field name="characteristic"/>
                <field name="related_party"/>
                <field name="related_service"/>
                <field name="test_measure"/>
                <field name="test_specification"/>
                <field name="valid_for"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_service_test_tree" model="ir.ui.view">
        <field name="name">tmf.service.test.tree</field>
        <field name="model">tmf.service.test</field>
        <field name="arch" type="xml">
            <list>
                <field name="description"/>
                <field name="end_date_time"/>
                <field name="mode"/>
                <field name="name"/>
                <field name="start_date_time"/>
                <field name="state"/>
                <field name="characteristic"/>
                <field name="related_party"/>
                <field name="related_service"/>
                <field name="test_measure"/>
                <field name="test_specification"/>
                <field name="valid_for"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_service_test" model="ir.actions.act_window">
        <field name="name">ServiceTest</field>
        <field name="res_model">tmf.service.test</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_service_test"
              name="ServiceTest"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_service_test"/>
</odoo>
