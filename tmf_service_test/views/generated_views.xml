<odoo>
  <record id="view_tmf_service_test_tree" model="ir.ui.view">
    <field name="name">tmf.service.test.tree</field>
    <field name="model">tmf.service.test</field>
    <field name="arch" type="xml">
      <list>
        <field name="tmf_id"/>
        <field name="name"/>
        <field name="mode"/>
        <field name="state"/>
        <field name="start_date_time"/>
        <field name="end_date_time"/>
      </list>
    </field>
  </record>

  <record id="view_tmf_service_test_form" model="ir.ui.view">
    <field name="name">tmf.service.test.form</field>
    <field name="model">tmf.service.test</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="tmf_id" readonly="1"/>
            <field name="href" readonly="1"/>
            <field name="name"/>
            <field name="description"/>
            <field name="mode"/>
            <field name="state"/>
            <field name="start_date_time"/>
            <field name="end_date_time"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_tmf_service_test_spec_tree" model="ir.ui.view">
    <field name="name">tmf.service.test.specification.tree</field>
    <field name="model">tmf.service.test.specification</field>
    <field name="arch" type="xml">
      <list>
        <field name="tmf_id"/>
        <field name="name"/>
        <field name="version"/>
        <field name="lifecycle_status"/>
        <field name="last_update"/>
      </list>
    </field>
  </record>

  <record id="view_tmf_service_test_spec_form" model="ir.ui.view">
    <field name="name">tmf.service.test.specification.form</field>
    <field name="model">tmf.service.test.specification</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="tmf_id" readonly="1"/>
            <field name="href" readonly="1"/>
            <field name="name"/>
            <field name="description"/>
            <field name="is_bundle"/>
            <field name="version"/>
            <field name="lifecycle_status"/>
            <field name="last_update"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
</odoo>
