<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List view -->
    <record id="view_tmf_geographic_site_list" model="ir.ui.view">
        <field name="name">tmf.geographic.site.list</field>
        <field name="model">tmf.geographic.site</field>
        <field name="arch" type="xml">
            <list string="Geographic Sites">
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_tmf_geographic_site_form" model="ir.ui.view">
        <field name="name">tmf.geographic.site.form</field>
        <field name="model">tmf.geographic.site</field>
        <field name="arch" type="xml">
            <form string="Geographic Site">
                <sheet>
                    <group>
                        <field name="tmf_id" readonly="1"/>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="status"/>
                        <field name="description"/>
                    </group>

                    <group string="Calendar">
                        <field name="calendar_json" widget="text"/>
                    </group>

                    <group string="Place">
                        <field name="place_json" widget="text"/>
                    </group>

                    <group string="Related Parties">
                        <field name="related_party_json" widget="text"/>
                    </group>

                    <group string="Site Relationships">
                        <field name="site_relationship_json" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_tmf_geographic_site" model="ir.actions.act_window">
        <field name="name">Geographic Sites</field>
        <field name="res_model">tmf.geographic.site</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_tmf_geographic_site_root"
              name="TMF Geographic"
              parent="tmf_base.menu_tmf_root"
              sequence="50"/>

    <menuitem id="menu_tmf_geographic_site"
              name="Geographic Sites"
              parent="menu_tmf_geographic_site_root"
              action="action_tmf_geographic_site"
              sequence="10"/>

</odoo>
