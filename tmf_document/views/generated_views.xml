<odoo>
    <record id="view_tmf_document_form" model="ir.ui.view">
        <field name="name">tmf.document.form</field>
        <field name="model">tmf.document</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="creation_date"/>
                <field name="description"/>
                <field name="document_type"/>
                <field name="last_update"/>
                <field name="lifecycle_state"/>
                <field name="name"/>
                <field name="version"/>
                <field name="binary_attachment"/>
                <field name="category"/>
                <field name="characteristic"/>
                <field name="document_relationship"/>
                <field name="document_specification"/>
                <field name="related_entity"/>
                <field name="related_party"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_document_tree" model="ir.ui.view">
        <field name="name">tmf.document.tree</field>
        <field name="model">tmf.document</field>
        <field name="arch" type="xml">
            <list>
                <field name="creation_date"/>
                <field name="description"/>
                <field name="document_type"/>
                <field name="last_update"/>
                <field name="lifecycle_state"/>
                <field name="name"/>
                <field name="version"/>
                <field name="binary_attachment"/>
                <field name="category"/>
                <field name="characteristic"/>
                <field name="document_relationship"/>
                <field name="document_specification"/>
                <field name="related_entity"/>
                <field name="related_party"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_document" model="ir.actions.act_window">
        <field name="name">Document</field>
        <field name="res_model">tmf.document</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_document"
              name="Document"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_document"/>
</odoo>
