<odoo>
  <!-- FORM -->
  <record id="view_tmf_document_form" model="ir.ui.view">
    <field name="name">tmf.document.form</field>
    <field name="model">tmf.document</field>
    <field name="arch" type="xml">
      <form string="Document">
        <sheet>
          <group>
            <field name="name" required="1"/>
            <field name="status"/>
            <field name="document_type"/>
            <field name="version"/>
          </group>

          <group>
            <field name="creation_date"/>
            <field name="last_update"/>
          </group>

          <group>
            <field name="description"/>
          </group>

          <notebook>
            <page string="Attachment">
              <field name="attachment_json" widget="text"/>
            </page>

            <page string="Category">
              <field name="category_json" widget="text"/>
            </page>

            <page string="Characteristic">
              <field name="characteristic_json" widget="text"/>
            </page>

            <page string="Document refs">
              <field name="document_json" widget="text"/>
            </page>

            <page string="Document Specification">
              <field name="document_specification_json" widget="text"/>
            </page>

            <page string="External Identifier">
              <field name="external_identifier_json" widget="text"/>
            </page>

            <page string="Related">
              <group>
                <field name="related_entity_json" widget="text"/>
                <field name="related_party_json" widget="text"/>
              </group>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- TREE -->
  <record id="view_tmf_document_tree" model="ir.ui.view">
    <field name="name">tmf.document.tree</field>
    <field name="model">tmf.document</field>
    <field name="arch" type="xml">
      <list string="Documents">
        <field name="name"/>
        <field name="status"/>
        <field name="document_type"/>
        <field name="version"/>
        <field name="creation_date"/>
        <field name="last_update"/>
      </list>
    </field>
  </record>

  <!-- ACTION + MENU (optional if you already have them) -->
  <record id="action_tmf_document" model="ir.actions.act_window">
    <field name="name">Documents</field>
    <field name="res_model">tmf.document</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
