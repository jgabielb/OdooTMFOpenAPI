<odoo>
    <record id="view_tmf_digital_identity_tree" model="ir.ui.view">
        <field name="name">tmf.digital.identity.tree</field>
        <field name="model">tmf.digital.identity</field>
        <field name="arch" type="xml">
            <list string="DigitalIdentity">
                <field name="tmf_id"/>
                <field name="nickname"/>
                <field name="status"/>
                <field name="creation_date"/>
                <field name="last_update"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_digital_identity_form" model="ir.ui.view">
        <field name="name">tmf.digital.identity.form</field>
        <field name="model">tmf.digital.identity</field>
        <field name="arch" type="xml">
            <form string="DigitalIdentity">
                <sheet>
                    <group>
                        <field name="nickname"/>
                        <field name="status"/>
                        <field name="creation_date"/>
                        <field name="last_update"/>
                    </group>
                    <group>
                        <field name="credential_json"/>
                        <field name="party_role_identified_json"/>
                        <field name="individual_identified_json"/>
                        <field name="related_party_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_digital_identity" model="ir.actions.act_window">
        <field name="name">DigitalIdentity</field>
        <field name="res_model">tmf.digital.identity</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_digital_identity" name="DigitalIdentity" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_digital_identity"/>
</odoo>
