<odoo>
    <record id="view_tmf_ai_contract_specification_form" model="ir.ui.view">
        <field name="name">tmf.ai.contract.specification.form</field>
        <field name="model">tmf.ai.contract.specification</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="description"/>
                <field name="is_bundle"/>
                <field name="last_update"/>
                <field name="lifecycle_status"/>
                <field name="name"/>
                <field name="version"/>
                <field name="attachment"/>
                <field name="constraint"/>
                <field name="entity_spec_relationship"/>
                <field name="related_party"/>
                <field name="spec_characteristic"/>
                <field name="target_entity_schema"/>
                <field name="valid_for"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_ai_contract_specification_tree" model="ir.ui.view">
        <field name="name">tmf.ai.contract.specification.tree</field>
        <field name="model">tmf.ai.contract.specification</field>
        <field name="arch" type="xml">
            <list>
                <field name="description"/>
                <field name="is_bundle"/>
                <field name="last_update"/>
                <field name="lifecycle_status"/>
                <field name="name"/>
                <field name="version"/>
                <field name="attachment"/>
                <field name="constraint"/>
                <field name="entity_spec_relationship"/>
                <field name="related_party"/>
                <field name="spec_characteristic"/>
                <field name="target_entity_schema"/>
                <field name="valid_for"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_ai_contract_specification" model="ir.actions.act_window">
        <field name="name">Ai Contract Specification</field>
        <field name="res_model">tmf.ai.contract.specification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_ai_contract_specification"
              name="Ai Contract Specification"
              parent="tmf_base.menu_tmf_root"
              action="action_tmf_ai_contract_specification"/>
</odoo>
