<odoo>
    <!-- 1. LIST VIEW -->
    <record id="view_tmf_customer_list" model="ir.ui.view">
        <field name="name">tmf.customer.list</field>
        <field name="model">tmf.customer</field>
        <field name="arch" type="xml">
            <list string="TMF Customers">
                <field name="name"/>
                <field name="tmf_id"/>
                <!-- Added badges for better visibility -->
                <field name="status" widget="badge" decoration-success="status == 'active'"/>
                <field name="lifecycle_status"/>
            </list>
        </field>
    </record>

    <!-- 2. FORM VIEW -->
    <record id="view_tmf_customer_form" model="ir.ui.view">
        <field name="name">tmf.customer.form</field>
        <field name="model">tmf.customer</field>
        <field name="arch" type="xml">
            <form string="TMF Customer">
                <header>
                    <!-- Status bar makes it look like a real process -->
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Customer Name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="tmf_id"/>
                            <field name="lifecycle_status"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 3. ACTION -->
    <record id="action_tmf_customer" model="ir.actions.act_window">
        <field name="name">TMF Customers</field>
        <field name="res_model">tmf.customer</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first TMF Customer
            </p>
        </field>
    </record>

    <!-- 4. MENU -->
    <!-- This puts it inside your "TM Forum BSS" App -->
    <menuitem
        id="menu_tmf_customer"
        name="Customers"
        parent="tmf_product_catalog.menu_tmf_root"
        action="action_tmf_customer"
        sequence="5"/>
</odoo>