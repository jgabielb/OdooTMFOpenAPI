<odoo>
    <record id="view_tmf_customer_form" model="ir.ui.view">
        <field name="name">tmf.customer.form</field>
        <field name="model">tmf.customer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="name"/>
                <field name="status"/>
                <field name="status_reason"/>
                <field name="account"/>
                <field name="agreement"/>
                <field name="characteristic"/>
                <field name="contact_medium"/>
                <field name="credit_profile"/>
                <field name="engaged_party"/>
                <field name="payment_method"/>
                <field name="related_party"/>
                <field name="valid_for"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_customer_tree" model="ir.ui.view">
        <field name="name">tmf.customer.tree</field>
        <field name="model">tmf.customer</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="status"/>
                <field name="status_reason"/>
                <field name="account"/>
                <field name="agreement"/>
                <field name="characteristic"/>
                <field name="contact_medium"/>
                <field name="credit_profile"/>
                <field name="engaged_party"/>
                <field name="payment_method"/>
                <field name="related_party"/>
                <field name="valid_for"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_customer" model="ir.actions.act_window">
        <field name="name">Customer</field>
        <field name="res_model">tmf.customer</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_customer"
              name="Customer"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_customer"/>
</odoo>
