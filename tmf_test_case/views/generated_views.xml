<odoo>
    <record id="view_tmf_test_case_form" model="ir.ui.view">
        <field name="name">tmf.test.case.form</field>
        <field name="model">tmf.test.case</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="description"/>
                <field name="version"/>
                <field name="version_description"/>
                <field name="agreement"/>
                <field name="attribute"/>
                <field name="related_party"/>
                <field name="state"/>
                <field name="test_case_definition"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_test_case_tree" model="ir.ui.view">
        <field name="name">tmf.test.case.tree</field>
        <field name="model">tmf.test.case</field>
        <field name="arch" type="xml">
            <list>
                <field name="description"/>
                <field name="version"/>
                <field name="version_description"/>
                <field name="agreement"/>
                <field name="attribute"/>
                <field name="related_party"/>
                <field name="state"/>
                <field name="test_case_definition"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_test_case" model="ir.actions.act_window">
        <field name="name">TestCase</field>
        <field name="res_model">tmf.test.case</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_test_case"
              name="TestCase"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_test_case"/>
</odoo>
