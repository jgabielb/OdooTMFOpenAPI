<odoo>
    <record id="view_tmf_test_case_form" model="ir.ui.view">
        <field name="name">tmf.test.case.form</field>
        <field name="model">tmf.test.case</field>
        <field name="arch" type="xml">
            <form string="Test Case">
                <sheet>
                    <group>
                        <field name="description"/>
                        <field name="version"/>
                        <field name="version_description"/>
                        <field name="state"/>
                        <field name="test_case_definition_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_test_case_tree" model="ir.ui.view">
        <field name="name">tmf.test.case.tree</field>
        <field name="model">tmf.test.case</field>
        <field name="arch" type="xml">
            <list string="Test Case">
                <field name="description"/>
                <field name="version"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_test_case" model="ir.actions.act_window">
        <field name="name">Test Case</field>
        <field name="res_model">tmf.test.case</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_test_case" name="Test Case" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_test_case"/>

