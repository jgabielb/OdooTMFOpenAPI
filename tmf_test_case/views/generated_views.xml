                        <field name="version_description"/>
                        <field name="state"/>
                        <field name="non_functional_test_model_definition_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_non_functional_test_model_tree" model="ir.ui.view">
