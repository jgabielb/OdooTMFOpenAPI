<odoo>
    <record id="view_tmf_test_data_instance_definition_form" model="ir.ui.view">
        <field name="name">tmf.test.data.instance.definition.form</field>
        <field name="model">tmf.test.data.instance.definition</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="attachment_type"/>
                <field name="content"/>
                <field name="description"/>
                <field name="mime_type"/>
                <field name="name"/>
                <field name="url"/>
                <field name="size"/>
                <field name="valid_for"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_test_data_instance_definition_tree" model="ir.ui.view">
        <field name="name">tmf.test.data.instance.definition.tree</field>
        <field name="model">tmf.test.data.instance.definition</field>
        <field name="arch" type="xml">
            <list>
                <field name="attachment_type"/>
                <field name="content"/>
                <field name="description"/>
                <field name="mime_type"/>
                <field name="name"/>
                <field name="url"/>
                <field name="size"/>
                <field name="valid_for"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_test_data_instance_definition" model="ir.actions.act_window">
        <field name="name">Test Data Instance Definition</field>
        <field name="res_model">tmf.test.data.instance.definition</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_test_data_instance_definition"
              name="Test Data Instance Definition"
              parent="tmf_base.menu_tmf_root"
              action="action_tmf_test_data_instance_definition"/>
</odoo>
