<odoo>
    <record id="view_tmf_event_form" model="ir.ui.view">
        <field name="name">tmf.event.form</field>
        <field name="model">tmf.event</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="topic_id"/>
                <field name="correlation_id"/>
                <field name="description"/>
                <field name="domain"/>
                <field name="event_id"/>
                <field name="event_time"/>
                <field name="event_type"/>
                <field name="priority"/>
                <field name="time_occurred"/>
                <field name="title"/>
                <field name="analytic_characteristic"/>
                <field name="event_payload"/>
                <field name="related_party"/>
                <field name="reporting_system"/>
                <field name="source"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_event_tree" model="ir.ui.view">
        <field name="name">tmf.event.tree</field>
        <field name="model">tmf.event</field>
        <field name="arch" type="xml">
            <list>
                <field name="topic_id"/>
                <field name="correlation_id"/>
                <field name="description"/>
                <field name="domain"/>
                <field name="event_id"/>
                <field name="event_time"/>
                <field name="event_type"/>
                <field name="priority"/>
                <field name="time_occurred"/>
                <field name="title"/>
                <field name="analytic_characteristic"/>
                <field name="event_payload"/>
                <field name="related_party"/>
                <field name="reporting_system"/>
                <field name="source"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_event" model="ir.actions.act_window">
        <field name="name">Event</field>
        <field name="res_model">tmf.event</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_event"
              name="Event"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_event"/>
</odoo>
