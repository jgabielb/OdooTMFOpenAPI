<odoo>
    <record id="view_tmf_warranty_tree" model="ir.ui.view">
        <field name="name">tmf.warranty.tree</field>
        <field name="model">tmf.warranty</field>
        <field name="arch" type="xml">
            <list string="Warranty">
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="description"/>
                <field name="version"/>
                <field name="state"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_warranty_form" model="ir.ui.view">
        <field name="name">tmf.warranty.form</field>
        <field name="model">tmf.warranty</field>
        <field name="arch" type="xml">
            <form string="Warranty">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="version"/>
                        <field name="state"/>
                        <field name="status"/>
                        <field name="status_change_date"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="is_bundle"/>
                        <field name="is_external"/>
                    </group>
                    <group>
                        <field name="warranty_specification_json"/>
                        <field name="warranty_agreement_json"/>
                        <field name="warranty_relationship_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_warranty" model="ir.actions.act_window">
        <field name="name">Warranty</field>
        <field name="res_model">tmf.warranty</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_warranty" name="Warranty" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_warranty"/>

    <record id="view_tmf_warranty_specification_tree" model="ir.ui.view">
        <field name="name">tmf.warranty.specification.tree</field>
        <field name="model">tmf.warranty.specification</field>
        <field name="arch" type="xml">
            <list string="WarrantySpecification">
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="description"/>
                <field name="version"/>
                <field name="lifecycle_status"/>
            </list>
        </field>
    </record>

    <record id="view_tmf_warranty_specification_form" model="ir.ui.view">
        <field name="name">tmf.warranty.specification.form</field>
        <field name="model">tmf.warranty.specification</field>
        <field name="arch" type="xml">
            <form string="WarrantySpecification">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="version"/>
                        <field name="lifecycle_status"/>
                        <field name="last_update"/>
                        <field name="is_bundle"/>
                    </group>
                    <group>
                        <field name="spec_characteristic_json"/>
                        <field name="constraint_json"/>
                        <field name="warranty_duration_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tmf_warranty_specification" model="ir.actions.act_window">
        <field name="name">WarrantySpecification</field>
        <field name="res_model">tmf.warranty.specification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_warranty_specification" name="WarrantySpecification" parent="tmf_product_catalog.menu_tmf_root" action="action_tmf_warranty_specification"/>
</odoo>
