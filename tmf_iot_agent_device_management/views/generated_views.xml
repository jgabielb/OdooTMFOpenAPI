<odoo>
    <record id="view__tree" model="ir.ui.view">
        <field name="name">tmf.iot.agent.device.resource.tree</field>
        <field name="model">tmf.iot.agent.device.resource</field>
        <field name="arch" type="xml">
            <list string="TMF908 IoT Agent and Device Management">
                <field name="resource_type"/>
                <field name="tmf_id"/>
                <field name="name"/>
                <field name="status"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view__form" model="ir.ui.view">
        <field name="name">tmf.iot.agent.device.resource.form</field>
        <field name="model">tmf.iot.agent.device.resource</field>
        <field name="arch" type="xml">
            <form string="TMF908 IoT Agent and Device Management">
                <sheet>
                    <group>
                        <field name="resource_type"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="status"/>
                        <field name="state"/>
                        <field name="lifecycle_status"/>
                    </group>
                    <group>
                        <field name="payload_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_" model="ir.actions.act_window">
        <field name="name">TMF908 IoT Agent and Device Management</field>
        <field name="res_model">tmf.iot.agent.device.resource</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_" name="TMF908 IoT Agent and Device Management" parent="tmf_base.menu_tmf_root" action="action_"/>
</odoo>
