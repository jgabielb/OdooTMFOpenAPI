<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- List view -->
        <record id="view_tmf_api_key_list" model="ir.ui.view">
            <field name="name">tmf.api.key.list</field>
            <field name="model">tmf.api.key</field>
            <field name="arch" type="xml">
                <list string="TMF API Keys">
                    <field name="name"/>
                    <field name="key" string="API Key"/>
                    <field name="partner_id"/>
                    <field name="is_active"/>
                    <field name="create_date"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_tmf_api_key_form" model="ir.ui.view">
            <field name="name">tmf.api.key.form</field>
            <field name="model">tmf.api.key</field>
            <field name="arch" type="xml">
                <form string="TMF API Key">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="key" string="API Key"
                                   help="Leave blank to auto-generate a UUID key on save."/>
                            <field name="partner_id"/>
                            <field name="is_active"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Window action -->
        <record id="action_tmf_api_key" model="ir.actions.act_window">
            <field name="name">TMF API Keys</field>
            <field name="res_model">tmf.api.key</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p>Manage API keys that grant access to the TMF Open API endpoints.</p>
                <p>Leave the Key field blank when creating a new record to auto-generate a UUID key.</p>
                <p>Enable authentication via Settings &gt; Technical &gt; Parameters:
                   set <b>tmf.api.auth.enabled</b> to <b>True</b>.</p>
            </field>
        </record>

        <!-- Menu items -->
        <menuitem id="menu_tmf_api_security_root"
                  name="Security"
                  parent="tmf_base.menu_tmf_root"
                  sequence="30"
                  groups="base.group_system"/>

        <menuitem id="menu_tmf_api_key"
                  name="API Keys"
                  parent="menu_tmf_api_security_root"
                  action="action_tmf_api_key"
                  sequence="10"
                  groups="base.group_system"/>

    </data>
</odoo>
