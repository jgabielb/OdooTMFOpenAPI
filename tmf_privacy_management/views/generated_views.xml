<odoo>
    <record id="view_tmf_privacy_management_resource_form" model="ir.ui.view">
        <field name="name">tmf.privacy.management.resource.form</field>
        <field name="model">tmf.privacy.management.resource</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="resource_type"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="status"/>
                        <field name="state"/>
                        <field name="lifecycle_status"/>
                        <field name="tmf_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_privacy_management_resource_list" model="ir.ui.view">
        <field name="name">tmf.privacy.management.resource.list</field>
        <field name="model">tmf.privacy.management.resource</field>
        <field name="arch" type="xml">
            <list>
                <field name="resource_type"/>
                <field name="name"/>
                <field name="status"/>
                <field name="state"/>
                <field name="lifecycle_status"/>
                <field name="tmf_id"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_privacy_management_resource" model="ir.actions.act_window">
        <field name="name">TMF644 Privacy</field>
        <field name="res_model">tmf.privacy.management.resource</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_privacy_management_resource"
              name="TMF644 Privacy"
              parent="tmf_product_catalog.menu_tmf_root"
              action="action_tmf_privacy_management_resource"/>
</odoo>
