<odoo>
    <record id="view_tmf_geographic_location_form" model="ir.ui.view">
        <field name="name">tmf.geographic.location.form</field>
        <field name="model">tmf.geographic.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="tmf_type"/>
                        <field name="geometry_type"/>
                        <field name="accuracy"/>
                        <field name="spatial_ref"/>
                    </group>
                    <group>
                        <field name="geometry" widget="text"/>
                        <field name="bbox"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tmf_geographic_location_list" model="ir.ui.view">
        <field name="name">tmf.geographic.location.list</field>
        <field name="model">tmf.geographic.location</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="tmf_type"/>
                <field name="geometry_type"/>
                <field name="spatial_ref"/>
                <field name="accuracy"/>
            </list>
        </field>
    </record>

    <record id="action_tmf_geographic_location" model="ir.actions.act_window">
        <field name="name">Geographic Location</field>
        <field name="res_model">tmf.geographic.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tmf_geographic_location"
              name="Geographic Location"
              parent="tmf_base.menu_tmf_root"
              action="action_tmf_geographic_location"/>
</odoo>
